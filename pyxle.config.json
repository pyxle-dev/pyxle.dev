{
  "plugins": [
    {
      "name": "pyxle-db",
      "settings": {
        "path": "data/pyxle.db",
        "migrationsDir": "migrations"
      }
    }
  ],
  "middleware": [],
  "cache": {
    "/": 60,
    "/benchmarks": 3600,
    "/docs/*": 1800
  },
  "csrf": {
    "exemptPaths": [
      "/api/__actions/"
    ]
  }
}
