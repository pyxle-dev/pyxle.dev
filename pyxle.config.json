{
  "plugins": [
    {
      "name": "pyxle-db",
      "settings": {
        "path": "data/pyxle.db",
        "migrationsDir": "migrations"
      }
    },
    {
      "name": "pyxle-mail"
    }
  ],
  "middleware": [],
  "cache": {
    "/": 60,
    "/compare": 1800,
    "/benchmarks": 3600,
    "/docs/*": 1800,
    "/plugins": 1800,
    "/roadmap": 1800
  },
  "csrf": {
    "exemptPaths": [
      "/api/__actions/",
      "/api/unsubscribe",
      "/api/resend-webhook"
    ]
  },
  "llms": {
    "enabled": true
  }
}
