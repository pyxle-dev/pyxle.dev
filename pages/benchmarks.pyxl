                <meta property="og:description" content="See how Pyxle performs against popular Python and Node.js frameworks." />
                <meta property="og:image" content="https://pyxle.dev/branding/og-default.png" />
                <meta property="og:type" content="website" />
                <meta name="twitter:card" content="summary_large_image" />
                <meta name="twitter:image" content="https://pyxle.dev/branding/og-default.png" />
            </Head>
            <main id="main">

            {/* Hero */}
            <section className="relative isolate overflow-hidden px-6 pt-24 pb-12 sm:pt-28">
                <div aria-hidden="true" className="pointer-events-none absolute inset-0 -z-10">
                    <div className="absolute inset-0 grid-bg opacity-40" />
                    <div className="aurora aurora-anim parallax-slow absolute -inset-x-10 -top-48 h-[560px] origin-top" />
                    <div className="absolute inset-x-0 bottom-0 h-32 bg-gradient-to-b from-transparent to-white dark:to-[#0a0a0b]" />
                </div>
                <div className="mx-auto max-w-6xl">
                    <p className="reveal text-xs font-semibold uppercase tracking-[0.18em] text-emerald-700 dark:text-emerald-400 mb-3">Performance</p>
                    <h1 className="reveal text-balance text-4xl font-semibold leading-[1.02] tracking-[-0.02em] sm:text-5xl md:text-6xl" style={{ animationDelay: '60ms' }}>
                        Benchmarked <span className="gradient-text">in the open.</span>
                    </h1>
                    <p className="reveal mt-5 max-w-2xl text-pretty text-base sm:text-lg text-zinc-600 dark:text-zinc-400" style={{ animationDelay: '120ms' }}>
                        Reproducible benchmarks comparing Pyxle against popular web frameworks — every framework implements identical endpoints with the same logic. No cherry-picking, every number links to its harness.
                    </p>
                </div>
            </section>

            {/* Methodology */}
            <section className="px-6 pb-16">
                <div className="mx-auto max-w-6xl">
                    <div className={`rounded-xl border p-6 border-zinc-200 bg-zinc-50 dark:border-white/5 dark:bg-white/[0.02]`}>
                        <h2 className="text-sm font-semibold uppercase tracking-widest text-emerald-700 dark:text-emerald-400 mb-3">Methodology</h2>
                        <div className="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
                            {[
                                { label: "Tool", value: "autocannon v8" },
                                { label: "Duration", value: "10s per test" },
                                { label: "Connections", value: "10 + 50 concurrent" },
                                { label: "Hardware", value: "Apple M3 (8 cores)" },
                            ].map(m => (
                                <div key={m.label}>
                                    <p className={`text-xs text-zinc-600 dark:text-zinc-400`}>{m.label}</p>
                                    <p className="text-sm font-medium">{m.value}</p>
                                </div>
                            ))}
                        </div>
                        <p className={`mt-4 text-xs text-zinc-600 dark:text-zinc-400`}>
                            Charts show 50 concurrent connections (also measured at 10, with consistent results). The async Python frameworks (Pyxle, FastAPI, Django) run on uvicorn (single ASGI worker); Flask runs on gunicorn with gthread workers, since it's synchronous. Node.js frameworks use their default server; Next.js runs <code className="font-mono">next start</code> (production) with API routes and SSR pages rendered dynamically. Pyxle runs production mode via <code className="font-mono">pyxle serve</code> with its full middleware stack. Database: SQLite (WAL), 1,000 pre-seeded rows.{' '}
                            <a href="https://github.com/pyxle-dev/benchmarks" target="_blank" rel="noreferrer" className="text-emerald-700 dark:text-emerald-400 underline underline-offset-2 hover:no-underline">
                                Source code (run it yourself)
                            </a>
                        </p>
