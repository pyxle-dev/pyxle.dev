                                        : 'text-zinc-600 border border-zinc-200 hover:bg-zinc-50 dark:text-zinc-400 dark:border dark:border-white/10 dark:hover:bg-white/5'
                                }`}
                            >
                                All Frameworks
                            </button>
                        </div>
                    </div>

                    <div className="grid gap-6 lg:grid-cols-2">
                        {Object.entries(TESTS).map(([key, test]) => (
                            <TestCard key={key} testKey={key} test={test} frameworks={activeFrameworks} />
                        ))}
                    </div>

                    {/* Context notes */}
                    <div className={`mt-6 rounded-xl border p-5 border-zinc-200 bg-zinc-50 dark:border-white/5 dark:bg-white/[0.02]`}>
                        <h3 className="text-sm font-semibold mb-2">Reading these results</h3>
                        <p className={`text-sm leading-relaxed text-zinc-600 dark:text-zinc-400`}>
                            Pyxle is a <strong>full-stack framework</strong> serving these endpoints through its production middleware stack — yet it matches or beats FastAPI, the leanest Python API framework, on JSON serialization and form handling. On purely SQLite-bound reads the multi-process synchronous frameworks (Flask, Django) pull ahead, because a single async worker serializes blocking database calls — an honest, expected trade-off.
                            {showAllFrameworks ? (
                                <> Node.js frameworks (Express, Hono) sit far higher still: they benefit from V8's optimized HTTP pipeline and native C++ SQLite bindings (<code className={`font-mono text-xs rounded px-1 py-0.5 bg-zinc-200 dark:bg-white/5`}>better-sqlite3</code>), so cross-runtime comparisons are inherently uneven — they're here for context, not as a like-for-like target.</>
                            ) : null}
                            {' '}The headline: you get SSR, server actions, and Python's whole ecosystem in one framework, at throughput on par with the fastest Python API server.
                        </p>
                    </div>
                </div>
            </section>

            {/* Reproduce */}
            <section className="px-6 pb-20">
                <div className="mx-auto max-w-6xl">
                    <div className={`rounded-xl border p-6 sm:p-8 text-center border-zinc-200 bg-zinc-50 dark:border-white/5 dark:bg-white/[0.02]`}>
                        <h2 className="text-xl font-bold mb-3">Run the benchmarks yourself</h2>
                        <p className={`text-sm mb-6 max-w-xl mx-auto text-zinc-600 dark:text-zinc-400`}>
                            All benchmark code is open source. Clone the repo, start the servers, and run the suite on your own hardware.
                        </p>
                        <a
                            href="https://github.com/pyxle-dev/benchmarks"
                            target="_blank"
                            rel="noreferrer"
                            className={`inline-flex items-center gap-2 rounded-xl px-6 py-3 text-sm font-semibold transition bg-zinc-900 text-white hover:bg-zinc-700 dark:bg-white dark:text-black dark:hover:bg-zinc-200`}
                        >
                            <svg className="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
                                <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z" />
                            </svg>
                            View benchmark source
                        </a>
                    </div>
                </div>
            </section>

            </main>
            <BenchFooter />
        </>
    );
}

const BENCH_FOOTER_COLS = [
    { h: 'Product', links: [['Docs', '/docs'], ['Playground', '/playground'], ['Benchmarks', '/benchmarks'], ['FAQ', '/docs/faq']] },
    { h: 'Learn', links: [['Getting started', '/docs/getting-started/installation'], ['Server actions', '/docs/core-concepts/server-actions'], ['For AI agents', '/docs/guides/for-ai-agents']] },
    { h: 'Community', links: [['GitHub', 'https://github.com/pyxle-dev/pyxle', true], ['Issues', 'https://github.com/pyxle-dev/pyxle/issues', true], ['Benchmark source', 'https://github.com/pyxle-dev/benchmarks', true]] },
];

function BenchFooter() {
    const linkCls = 'text-sm text-zinc-600 hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-white transition-colors';
    return (
        <footer className="relative border-t border-zinc-200 dark:border-white/5">
            <div aria-hidden="true" className="gradient-edge-static absolute inset-x-0 top-0 h-px opacity-80" />
            <div className="mx-auto max-w-6xl px-5 sm:px-6 py-14">
                <div className="grid gap-10 sm:grid-cols-2 lg:grid-cols-4">
                    <div className="sm:col-span-2 lg:col-span-1">
                        <Link href="/" aria-label="Pyxle home" className="focus-ring inline-flex items-center gap-2 rounded">
                            <img src="/branding/pyxle-mark.svg" alt="" width="28" height="28" className="h-7 w-7" />
                            <span className="text-[15px] font-semibold tracking-tight">Pyxle</span>
                        </Link>
                        <p className="mt-3 max-w-xs text-sm text-zinc-500 dark:text-zinc-400">Python and React in one file. The full-stack framework that gets out of your way.</p>
                    </div>
                    {BENCH_FOOTER_COLS.map((col) => (
                        <div key={col.h}>
                            <h3 className="text-[11px] font-semibold uppercase tracking-wider text-zinc-500 dark:text-zinc-400">{col.h}</h3>
                            <ul className="mt-4 space-y-2.5">
                                {col.links.map(([label, href, ext]) => (
                                    <li key={label}>{ext ? <a href={href} target="_blank" rel="noreferrer" className={linkCls}>{label}</a> : <Link href={href} className={linkCls}>{label}</Link>}</li>
                                ))}
                            </ul>
                        </div>
                    ))}
                </div>
                <div className="mt-12 flex flex-col items-center justify-between gap-3 border-t border-zinc-200 pt-6 dark:border-white/5 sm:flex-row">
                    <p className="text-xs text-zinc-500 dark:text-zinc-400">Pyxle Framework — MIT licensed · open source.</p>
                    <p className="inline-flex items-center gap-1.5 font-mono text-[11px] text-zinc-500 dark:text-zinc-400"><span className="h-1.5 w-1.5 rounded-full bg-emerald-500" /> built with Pyxle</p>
                </div>
            </div>
        </footer>
    );
}
