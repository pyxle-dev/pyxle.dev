    return (
        <>
            <Head>
                <title>Benchmarks - Pyxle Framework</title>
                <meta name="description" content="Honest, reproducible benchmarks — Pyxle vs FastAPI, Django, Flask, Express, Hono, and Next.js. Faster than Next.js at dynamic SSR; on par with FastAPI on API throughput." />
                <meta name="viewport" content="width=device-width, initial-scale=1" />
