    useScrollReveal, CopyButton, CodeBlock, PMark,
    InkButton, EditorialLink, Plate, GpSection, GpHead, GalleyFooter,
} from './components/galley.jsx';


/* ════════════════════════════════════════════════════════════════
   GALLEY PROOF — the page is typeset like a printed argument.
   Flat paper/ink surfaces, hairline rules, hanging section numerals,
   figures with captions instead of cards — and a motion language
   built entirely from the logo's own gesture: a round-cap stroke
   that draws itself, and a dot that lands like a period.
   ════════════════════════════════════════════════════════════════ */


/* ── Hero ────────────────────────────────────────────────────────── */

const HERO_CONTENTS = [
    ['01', 'The file', 'the-file'],
    ['02', 'Interactive', 'playground'],
    ['03', 'In the box', 'in-the-box'],
    ['04', 'The numbers', 'numbers'],
    ['05', 'For the agents', 'agents'],
    ['06', 'As Markdown', 'markdown'],
    ['07', 'In the wild', 'demos'],
    ['08', 'Start', 'start'],
];

/* Fragment navigation no-ops on sections with content-visibility:auto
   (the gp-cv perf hint), so the contents links scroll programmatically.
   The href stays for semantics and middle-click/copy-link. */
function scrollToSection(e, id) {
    e.preventDefault();
    const el = document.getElementById(id);
    if (!el) return;
    const reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    el.scrollIntoView({ behavior: reduce ? 'auto' : 'smooth', block: 'start' });
    history.replaceState(null, '', `#${id}`);
}

function Hero({ version }) {
    return (
        <section className="relative">
            <div className="mx-auto max-w-[76rem] px-5 pb-16 pt-28 sm:px-8 sm:pb-24 sm:pt-36">
                <div className="grid gap-12 lg:grid-cols-12">
                    {/* The whole hero paints statically — instant, like the
                       page was simply already there. Only the brand gestures
                       perform: the P draws itself and the period lands. */}
                    <div className="lg:col-span-9">
                        <PMark load id="hero" dur={600} dotDelay={650} />
                        <p className="mt-10 font-mono text-xs uppercase tracking-[0.14em] text-ink2">
                            Pyxle — an open-source, full-stack Python framework
                        </p>
                        <h1 className="mt-5 font-display text-[2.9rem] font-[560] leading-[1.04] tracking-[-0.015em] text-ink sm:text-[4.2rem] lg:text-[5.2rem]">
                            Python &amp; React.
                            <br />
                            One&nbsp;file<span className="gp-dot-load ml-[0.08em] inline-block h-[0.12em] w-[0.12em] rounded-full bg-accent" style={{ ['--dot-delay']: '700ms' }} aria-hidden="true" />
                            <span className="sr-only">.</span>
                        </h1>
                        <p className="mt-7 max-w-[56ch] text-pretty text-lg leading-[1.7] text-ink2">
                            The async loader, the server actions, and the React component that
                            uses them live together in a single{' '}
                            <code className="text-[0.9em] text-acct">.pyxl</code> file —
                            server-rendered, hydrated, hot-reloading. Standard ASGI underneath,
                            with no special deploy story.
                        </p>
                        <div className="mt-9 flex flex-wrap items-center gap-5">
                            <InkButton href="/docs/getting-started/installation">Get started</InkButton>
                            <EditorialLink href="/playground">Open the playground →</EditorialLink>
                        </div>
                        <p className="mt-7 font-mono text-xs text-ink2">
                            MIT{version ? ` · v${version}` : ''} ·{' '}
                            <Link href="/benchmarks" className="focus-ring rounded text-acct underline decoration-1 underline-offset-4 hover:decoration-2">
                                up to 4.3× faster SSR than Next.js →
                            </Link>
                        </p>
                    </div>

                    {/* Right rail — a manuscript's table of contents up top,
                       the pip colophon anchored at the bottom. */}
                    <div className="flex flex-col justify-between gap-12 lg:col-span-3">
                        <nav aria-label="Contents" className="hidden pt-3 lg:block">
                            <p className="font-mono text-[11px] uppercase tracking-[0.14em] text-press">Contents</p>
                            <ol className="mt-4">
                                {HERO_CONTENTS.map(([n, label, id]) => (
                                    <li key={n}>
                                        <a href={`#${id}`} onClick={(e) => scrollToSection(e, id)} className="focus-ring group flex items-baseline gap-3 rounded py-1.5">
                                            <span className="font-mono text-[11px] text-press" aria-hidden="true">{n}</span>
                                            <span className="gp-leader group-hover:border-accent" aria-hidden="true" />
                                            <span className="font-mono text-[12px] text-ink2 transition-colors group-hover:text-ink">{label}</span>
                                        </a>
                                    </li>
                                ))}
                            </ol>
                        </nav>
                        <div className="border-t border-rule pt-5">
                            <div className="flex items-center gap-3 font-mono text-[13px] text-ink">
                                <span className="select-none text-acct">$</span>
                                <span className="truncate">pip install pyxle-framework</span>
                                <span className="ml-auto"><CopyButton text="pip install pyxle-framework" /></span>
                            </div>
                            <p className="mt-3 font-mono text-[11px] text-ink2">Python 3.10+ · Node · any ASGI host</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    );
}


/* ── 01 · The file (the wedge + the Deletion) ────────────────────── */

const OLD_WAY_FILES = [
    'app/api/likes/route.ts',
    'lib/validators.ts',
    'types/likes.d.ts',
    'hooks/use-likes.ts',
    'lib/api-client.ts',
    'components/LikeButton.tsx',
    'components/LikeButtonSkeleton.tsx',
    'app/posts/[id]/page.tsx',
];

const LIKES_PYXL = `# likes.pyxl

@server
async def load(request):
    pid = request.path_params["id"]
    return {"id": pid, "likes": await db.likes(pid)}

@action
async def toggle_like(request):
    body = await request.json()
    return {"likes": await db.toggle(body["id"])}


import React from 'react';
import { useAction } from 'pyxle/client';

export default function Likes({ data }) {
    const toggle = useAction('toggle_like');
    return (
        <button onClick={() => toggle({ id: data.id })}>
            ♥ {data.likes} likes
        </button>
    );
}`;

/* One filename, struck out by a hand-drawn pen stroke. The slight
   sag in the path is what makes it a pen, not a text-decoration. */
function StruckFile({ name, i }) {
    return (
        <li style={{ ['--i']: i }}>
            <span className="relative inline-block">
                <span className="gp-struck-text font-mono text-[13px] leading-[2.3] text-ink2 sm:text-[15px]">{name}<span className="sr-only"> (replaced)</span></span>
                <svg className="gp-strike pointer-events-none absolute inset-0 h-full w-full" viewBox="0 0 100 24" preserveAspectRatio="none" aria-hidden="true">
                    <path d="M -1 13.5 C 30 11.8, 70 14.8, 101 12.6" pathLength="1" fill="none" stroke="var(--c-accent)" strokeWidth="1.6" strokeLinecap="round" />
                </svg>
            </span>
        </li>
    );
}

const MARGINALIA = [
    { top: '15%', note: 'runs on the server' },
    { top: '36%', note: 'the API layer, gone' },
    { top: '63%', note: 'same file renders both' },
];

function TheFile() {
    return (
        <GpSection n="01" id="the-file">
            <GpHead
                n="01"
                eyebrow="The file"
                title="Eight files was never the point."
                lead="A feature in a typical React-plus-API stack: a route handler, a validator, a types file, a client hook, a fetch wrapper, a skeleton, the component, and the page that mounts it — stitched together by convention and hope. In Pyxle, the same feature is one file. One read tells you everything it does."
            />

            <div className="mt-14 grid items-start gap-12 lg:grid-cols-12">
                {/* The Deletion */}
                <div data-reveal data-rt="late" className="min-w-0 lg:col-span-5">
                    <p className="font-mono text-[11px] uppercase tracking-[0.14em] text-ink2">The usual way</p>
                    <ul className="mt-4">
                        {OLD_WAY_FILES.map((f, i) => <StruckFile key={f} name={f} i={i} />)}
                    </ul>
                    <div className="mt-5">
                        <span className="relative inline-block">
                            <span className="font-mono text-[15px] font-medium text-ink sm:text-lg">likes.pyxl</span>
                            <svg className="pointer-events-none absolute -bottom-1.5 left-0 h-[5px] w-full" viewBox="0 0 100 5" preserveAspectRatio="none" aria-hidden="true">
                                <path d="M0 2.5 H100" pathLength="1" className="gp-draw" style={{ ['--draw-delay']: '1080ms', ['--draw-dur']: '320ms' }} fill="none" stroke="var(--c-accent)" strokeWidth="2.5" strokeLinecap="round" />
                            </svg>
                            <span className="gp-dot absolute -right-3.5 bottom-0 h-2 w-2 rounded-full bg-accent" style={{ ['--dot-delay']: '1400ms' }} aria-hidden="true" />
                        </span>
                        <span className="ml-7 font-mono text-xs text-ink2">— the same feature</span>
                    </div>
                </div>

                {/* Fig. 1 — the file itself, with proofreader's marginalia */}
                <div data-reveal className="min-w-0 lg:col-span-7" style={{ ['--reveal-delay']: '120ms' }}>
                    <Plate
                        label="likes.pyxl"
                        meta="24 lines"
                        caption={<>Fig. 1 — <span className="text-ink">likes.pyxl</span>, complete. This is not an excerpt.</>}
                    >
                        <div className="duotone relative">
                            <CodeBlock code={LIKES_PYXL} className="p-5 text-[12.5px]" />
                            {MARGINALIA.map((m) => (
                                <span key={m.note} className="absolute right-4 hidden items-center gap-2 xl:flex" style={{ top: m.top }} aria-hidden="true">
                                    <span className="h-px w-6" style={{ background: 'var(--c-press)', opacity: 0.6 }} />
                                    <span className="font-mono text-[11px] italic text-press">{m.note}</span>
                                </span>
                            ))}
                        </div>
                    </Plate>
                </div>
            </div>
        </GpSection>
    );
}


