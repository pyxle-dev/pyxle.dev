/* ── 08 · Start (a recipe) + the newsletter coda ─────────────────── */

const RECIPE = [
    ['pip install pyxle-framework', 'installs the compiler, server, and CLI'],
    ['pyxle init my-app && cd my-app', 'scaffolds pages/, config, and a first route'],
    ['pyxle install', 'installs the pinned JS toolchain'],
    ['pyxle dev', 'SSR dev server with HMR at localhost:8000'],
];

const TURNSTILE_SRC = 'https://challenges.cloudflare.com/turnstile/v0/api.js?render=explicit';
let _turnstileLoader = null;
function loadTurnstile() {
    if (typeof window === 'undefined') return Promise.resolve(null);
    if (window.turnstile) return Promise.resolve(window.turnstile);
    if (_turnstileLoader) return _turnstileLoader;
    _turnstileLoader = new Promise((resolve, reject) => {
        const s = document.createElement('script');
        s.src = TURNSTILE_SRC;
        s.async = true;
        s.defer = true;
        s.onload = () => resolve(window.turnstile || null);
        s.onerror = reject;
        document.head.appendChild(s);
    });
    return _turnstileLoader;
}

function GetStarted() {
    // Turnstile site key — public, injected into the client bundle at build time
    // via the PYXLE_PUBLIC_ convention. Guarded so an unset key degrades to ''.
    const turnstileSiteKey = (import.meta.env && import.meta.env.PYXLE_PUBLIC_TURNSTILE_SITE_KEY) || '';
    const subscribe = useAction('subscribe_newsletter');
    const [email, setEmail] = useState('');
    const [status, setStatus] = useState(null);
    const [message, setMessage] = useState('');
    const successRef = useRef(null);

    // Cloudflare Turnstile — armed lazily on first focus of the email field so
    // the script never loads for visitors who don't engage the form.
    const widgetRef = useRef(null);
    const widgetIdRef = useRef(null);
    const [tsToken, setTsToken] = useState('');
    // True between a submit click and the Turnstile token landing — lets us
    // wait (and auto-submit) instead of erroring when the check isn't done yet.
    const [verifying, setVerifying] = useState(false);
    const verifyTimerRef = useRef(null);

    const armTurnstile = useCallback(() => {
        if (!turnstileSiteKey || widgetIdRef.current !== null) return;
        loadTurnstile().then((ts) => {
            if (!ts || !widgetRef.current || widgetIdRef.current !== null) return;
            widgetIdRef.current = ts.render(widgetRef.current, {
                sitekey: turnstileSiteKey,
                appearance: 'interaction-only',
                callback: setTsToken,
                'expired-callback': () => setTsToken(''),
                'error-callback': () => setTsToken(''),
            });
        }).catch(() => {});
    }, [turnstileSiteKey]);

    // The form unmounts on success — move focus to the confirmation so
    // keyboard users aren't dropped at the document body.
    useEffect(() => {
        if (status === 'success' && successRef.current) successRef.current.focus();
    }, [status]);

    // The network submit, shared by the direct path (token already present) and
    // the deferred path (token arrives after the click — see the effect below).
    const doSubscribe = useCallback(async (token) => {
        if (verifyTimerRef.current) {
            clearTimeout(verifyTimerRef.current);
            verifyTimerRef.current = null;
        }
        setVerifying(false);
        const result = await subscribe({ email, turnstileToken: token });
        if (result.ok) {
            setStatus('success');
            setMessage(result.message);
            setEmail('');
        } else {
            setStatus('error');
            setMessage(result.error);
            // Turnstile tokens are single-use — get a fresh one for the retry.
            if (widgetIdRef.current !== null && window.turnstile) {
                window.turnstile.reset(widgetIdRef.current);
                setTsToken('');
            }
        }
    }, [email, subscribe]);

    const handleSubmit = useCallback((e) => {
        e.preventDefault();
        setStatus(null);
        setMessage('');
        if (turnstileSiteKey && !tsToken) {
            // The token isn't ready (the widget is still arming, or a challenge
            // needs solving). Don't error — arm it and wait; the effect below
            // fires the submit the instant the token lands, so there's no
            // second click and no scary red error on a legitimate visitor.
            armTurnstile();
            setVerifying(true);
            setStatus('verifying');
            setMessage('One moment — running a quick human check…');
            if (verifyTimerRef.current) clearTimeout(verifyTimerRef.current);
            verifyTimerRef.current = setTimeout(() => {
                verifyTimerRef.current = null;
                setVerifying(false);
                setStatus('error');
                setMessage("Couldn't finish the human check — please try again.");
            }, 30000);
            return;
        }
        doSubscribe(tsToken);
    }, [turnstileSiteKey, tsToken, armTurnstile, doSubscribe]);

    // A submit is waiting on the human check and the token just arrived → send it.
    useEffect(() => {
        if (verifying && tsToken) doSubscribe(tsToken);
    }, [verifying, tsToken, doSubscribe]);

    // Drop the pending timer if we unmount mid-verify.
    useEffect(() => () => {
        if (verifyTimerRef.current) clearTimeout(verifyTimerRef.current);
    }, []);

    return (
        <GpSection n="08" id="start">
            <GpHead
                n="08"
                eyebrow="Start"
                title="Four commands. The fourth is a running app."
            />

            <div className="mt-12 grid gap-16 lg:grid-cols-12">
                {/* The recipe */}
                <div className="min-w-0 lg:col-span-7">
                    <ol className="border-t border-rule">
                        {RECIPE.map(([cmd, gloss], i) => (
                            <li key={cmd} data-reveal className="relative border-b border-rule py-4" style={{ ['--reveal-delay']: `${i * 90}ms` }}>
                                <div className="flex items-baseline gap-4">
                                    <span className="font-display text-lg font-[540] text-press" aria-hidden="true">{i + 1}</span>
                                    <div className="min-w-0 flex-1">
                                        <div className="flex items-baseline gap-3">
                                            <code className="truncate font-mono text-[13px] text-ink sm:text-sm">{cmd}</code>
                                            <span className="ml-auto shrink-0"><CopyButton text={cmd} /></span>
                                        </div>
                                        <p className="mt-1 font-mono text-[11px] text-ink2">{gloss}</p>
                                    </div>
                                </div>
                                {i === RECIPE.length - 1 && (
                                    <svg className="absolute -bottom-[2px] right-0 h-[3px] w-8" viewBox="0 0 32 3" fill="none" aria-hidden="true">
                                        <path d="M0 1.5 H32" pathLength="1" className="gp-draw" style={{ ['--draw-delay']: '500ms', ['--draw-dur']: '320ms' }} stroke="var(--c-accent)" strokeWidth="3" strokeLinecap="round" />
                                    </svg>
                                )}
                            </li>
                        ))}
                    </ol>
                    <p data-reveal className="mt-8 max-w-[58ch] text-pretty text-base leading-[1.7] text-ink2">
                        Then open <code className="text-[0.9em] text-acct">pages/</code>, add a file,
                        and you've shipped a route. The docs take it from there.
                    </p>
                    <div data-reveal className="mt-8 flex flex-wrap items-center gap-5">
                        <InkButton href="/docs">Read the docs</InkButton>
                        <EditorialLink href="https://github.com/pyxle-dev/pyxle" external>Star on GitHub ↗</EditorialLink>
                    </div>
                </div>

                {/* The coda — a form that is also the proof */}
                <div className="min-w-0 lg:col-span-5">
                    <div data-reveal style={{ ['--reveal-delay']: '150ms' }}>
                        <h3 className="font-display text-[1.5rem] font-[540] tracking-[-0.01em] text-ink">This form is the demo.</h3>
                        <p className="mt-3 max-w-[48ch] text-pretty text-sm leading-[1.7] text-ink2">
                            The input below posts to an <code className="text-[0.9em] text-acct">@action</code> defined
                            in <code className="text-[0.9em] text-acct">index.pyxl</code> — the file that rendered this
                            page. Release notes, occasionally. No noise.
                        </p>

                        {/* Persistent announcer — it exists in both states, so
                           the success swap is actually announced. The visible
                           block then receives focus so keyboard users follow. */}
                        <div role="status" aria-live="polite" className="sr-only">{status === 'success' ? message : ''}</div>
                        {status === 'success' ? (
                            <div className="mt-8">
                                <p ref={successRef} tabIndex={-1} className="font-display text-xl font-[460] leading-snug text-ink focus:outline-none">
                                    {message}
                                    <span className="gp-dot-load ml-[0.35em] inline-block h-[0.14em] w-[0.14em] rounded-full bg-accent" style={{ ['--dot-delay']: '150ms' }} aria-hidden="true" />
                                </p>
                                <p className="mt-3 font-mono text-[11px] text-ink2">— returned by subscribe_newsletter() just now.</p>
                            </div>
                        ) : (
                            <>
                                <form onSubmit={handleSubmit} className="mt-8 flex items-end gap-4">
                                    <label htmlFor="newsletter-email" className="sr-only">Email address</label>
                                    <input
                                        id="newsletter-email"
                                        type="email"
                                        value={email}
                                        onChange={(e) => { setEmail(e.target.value); setStatus(null); }}
                                        onFocus={armTurnstile}
                                        placeholder="you@example.com"
                                        required
                                        autoComplete="email"
                                        className="gp-baseline-input w-full min-w-0 flex-1 font-mono text-sm text-ink placeholder:text-ink2"
                                    />
                                    <button
                                        type="submit"
                                        disabled={verifying || subscribe.pending}
                                        className="focus-ring shrink-0 rounded-[3px] bg-ink px-5 py-2.5 font-mono text-[13px] text-paper transition-opacity hover:opacity-85 disabled:cursor-not-allowed disabled:opacity-50"
                                    >
                                        {verifying ? 'Verifying…' : subscribe.pending ? 'Sending…' : 'Subscribe'}
                                    </button>
                                </form>
                                <div ref={widgetRef} className="mt-3 empty:hidden" />
                                <div className="min-h-[1.5rem] pt-2" aria-live="polite">
                                    {status === 'error' && <p className="font-mono text-xs text-red-600 dark:text-red-400">error: {message}</p>}
                                    {status === 'verifying' && <p className="font-mono text-xs text-ink2">{message}</p>}
                                </div>
                                <p className="mt-2 font-mono text-[11px] leading-relaxed text-ink2">
                                    def subscribe_newsletter(request) · validated, rate-limited, and stored by{' '}
                                    <Link href="/docs/core-concepts/server-actions" className="focus-ring rounded text-acct underline decoration-1 underline-offset-2 hover:decoration-2">an @action</Link> on this server.
                                </p>
                            </>
                        )}
                    </div>
                </div>
            </div>
        </GpSection>
    );
}


/* ── Page ────────────────────────────────────────────────────────── */

export const slots = {
    'nav-extra': () => (
        <a
            href="https://github.com/pyxle-dev/pyxle.dev/blob/main/pages/index.pyxl"
            target="_blank"
            rel="noreferrer"
            title="View this page's source"
            className="focus-ring hidden rounded font-mono text-[13px] text-ink2 transition-colors hover:text-ink lg:inline"
        >
            source ↗
        </a>
    ),
};
export const createSlots = () => slots;

export default function Page({ data }) {
    useScrollReveal();
    const version = data && data.version;
    return (
        <>
            <Head>
                <title>Pyxle — Python + React in one file</title>
                <meta name="description" content="The full-stack Python framework. Async server loaders, React UI, and server actions in a single .pyxl file. SSR, file-based routing, zero glue code." />
                <meta name="viewport" content="width=device-width, initial-scale=1" />
                <meta name="theme-color" content="#101411" />
                <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
                <link rel="alternate icon" href="/favicon.ico" />
                <meta property="og:title" content="Pyxle — Python + React in one file" />
                <meta property="og:description" content="The full-stack Python framework. Python loaders, React UI, server actions — zero glue code." />
                <meta property="og:type" content="website" />
                <meta property="og:url" content="https://pyxle.dev" />
                <meta property="og:image" content="https://pyxle.dev/branding/og-default.png" />
                <meta name="twitter:card" content="summary_large_image" />
                <meta name="twitter:image" content="https://pyxle.dev/branding/og-default.png" />
            </Head>
            <main id="main">
                <Hero version={version} />
                <TheFile />
                <Centerfold />
                <TheIndex />
                <TheNumbers />
                <ForAgents />
                <ReadableAsMarkdown />
                <InTheWild />
                <GetStarted />
            </main>
            <GalleyFooter version={version} />
        </>
    );
}
