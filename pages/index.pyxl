                                                    <span className="font-mono text-[11px] text-zinc-200">{p.label}</span>
                                                </div>
                                                <p className="mt-1 text-[11px] leading-snug text-zinc-500">{p.role}</p>
                                            </div>
                                        ))}
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    );
}


/* ── Features (merged with hero code section feel) ───────────────── */

function BentoCell({ className = '', icon, title, children, delay = 0 }) {
    return (
        <div
            data-reveal
            style={{ ['--reveal-delay']: `${delay}ms` }}
            className={`group relative flex flex-col rounded-2xl border p-5 sm:p-6 transition-all duration-300 border-zinc-200 bg-white hover:-translate-y-0.5 hover:shadow-lg hover:shadow-zinc-900/5 hover:border-zinc-300 dark:border-white/5 dark:bg-white/[0.02] dark:hover:border-white/10 dark:hover:shadow-black/30 ${className}`}
        >
            <div className="mb-4 inline-flex h-9 w-9 items-center justify-center rounded-lg border border-zinc-200 bg-zinc-50 text-emerald-700 transition-colors group-hover:border-emerald-500/30 group-hover:text-emerald-600 dark:border-white/10 dark:bg-white/5 dark:text-emerald-400">
                <svg className="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" strokeWidth="1.6" aria-hidden="true">
                    <path strokeLinecap="round" strokeLinejoin="round" d={icon} />
                </svg>
            </div>
            <h3 className="text-[15px] font-semibold">{title}</h3>
            {children}
        </div>
    );
}

function Features() {
