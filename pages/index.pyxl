                            />
                            <div className="gradient-edge h-full rounded-2xl p-px shadow-xl shadow-emerald-500/10 dark:shadow-black/40">
                                <div className="flex h-full flex-col overflow-hidden rounded-2xl bg-[#0b0b0d]">
                                    <div className="flex items-center gap-2 border-b border-white/5 px-4 py-2.5">
                                        <span className="flex gap-1.5" aria-hidden="true">
                                            <span className="h-2.5 w-2.5 rounded-full bg-zinc-600/80" />
