            </div>
        </section>
    );
}


/* ── Built for AI agents (condensed) ─────────────────────────────── */

const AGENT_POINTS = [
    {
        title: 'Python the whole way',
        desc: 'Frontier LLMs write Python with the highest confidence. Backend stays in their strongest mode, and the AI SDK ecosystem (Anthropic, OpenAI, LangChain) is Python-first anyway.',
    },
    {
        title: 'One file per feature',
        desc: 'Loader, mutation, and React UI in a single .pyxl file. One read = full feature understanding. No 7-file CRUD edits, no TS/Python type sync.',
    },
    {
        title: 'Machine-parseable errors',
        desc: 'pyxle check emits [section] line N: message — one diagnostic per line, exit 0/1. Tight edit → check → fix loops with grep-friendly output.',
    },
];

function ForAgents() {
    return (
        <section id="agents" className="relative px-5 sm:px-6 py-16 sm:py-20">
            <div className="mx-auto max-w-6xl">
                <div data-reveal className="text-center mb-12">
                    <p className="text-xs font-semibold uppercase tracking-[0.18em] text-emerald-700 dark:text-emerald-400">For AI coding agents</p>
                    <h2 className="mt-3 text-balance text-3xl sm:text-4xl font-semibold tracking-tight">
                        The framework <span className="gradient-text">AI agents love</span>.
                    </h2>
                    <p className="mx-auto mt-4 max-w-xl text-pretty text-sm sm:text-base text-zinc-600 dark:text-zinc-400">
                        Tiny CLI surface, zero magic, one file per feature. Built so Claude, Cursor, and Copilot ship real features with a fraction of the context.
                    </p>
                </div>

                <div className="grid items-center gap-5 lg:grid-cols-2 lg:gap-8">
                    {/* The three points */}
                    <div className="space-y-3">
                        {AGENT_POINTS.map((p, i) => (
                            <div
                                key={p.title}
                                data-reveal="left"
                                className="flex gap-3.5 rounded-xl border p-5 border-zinc-200 bg-white dark:border-white/5 dark:bg-white/[0.02]"
                                style={{ ['--reveal-delay']: `${i * 70}ms` }}
                            >
                                <span className="mt-1.5 h-2 w-2 shrink-0 rounded-full bg-gradient-to-br from-emerald-400 to-cyan-400" />
                                <div>
                                    <h3 className="text-[15px] font-semibold">{p.title}</h3>
                                    <p className="mt-1 text-sm leading-relaxed text-zinc-600 dark:text-zinc-400">{p.desc}</p>
                                </div>
                            </div>
                        ))}
                    </div>

                    {/* The proof: literal machine-parseable check output */}
                    <div data-reveal="right" style={{ ['--reveal-delay']: '120ms' }}>
                        <div className="overflow-hidden rounded-2xl border border-white/10 bg-[#0b0b0d] shadow-xl shadow-black/30">
                            <div className="flex items-center gap-2 border-b border-white/5 px-4 py-2.5">
                                <span className="flex gap-1.5" aria-hidden="true">
                                    <span className="h-2.5 w-2.5 rounded-full bg-zinc-600/80" />
                                    <span className="h-2.5 w-2.5 rounded-full bg-zinc-600/60" />
                                    <span className="h-2.5 w-2.5 rounded-full bg-zinc-600/40" />
                                </span>
                                <span className="ml-1 font-mono text-[11px] text-zinc-400">terminal</span>
                            </div>
                            <pre className="overflow-x-auto p-5 font-mono text-[12.5px] leading-[1.85]">
                                <code>
                                    <div><span className="sh-cmd">$</span> <span className="text-zinc-200">pyxle check</span></div>
                                    {'\n'}
                                    <div><span className="sh-comp">[server]</span> <span className="text-zinc-400">pages/users.pyxl:7:</span> <span className="sh-elem">loader must return a dict</span></div>
                                    <div><span className="sh-comp">[jsx]</span> <span className="text-zinc-400">pages/users.pyxl:21:</span> <span className="sh-elem">data.users may be undefined</span></div>
                                    {'\n'}
                                    <div><span className="sh-elem">✗</span> <span className="text-zinc-300">2 problems</span> <span className="text-zinc-600">·</span> <span className="sh-dec">exit 1</span></div>
                                </code>
                            </pre>
                        </div>
                        <p className="mt-3 text-center font-mono text-[11px] text-zinc-500 dark:text-zinc-500">one diagnostic per line · grep-friendly · exit 0/1</p>
                    </div>
                </div>

                <div className="mt-10 text-center">
                    <Link
                        href="/docs/guides/for-ai-agents"
                        className="focus-ring inline-flex items-center gap-1.5 text-sm font-medium text-emerald-700 dark:text-emerald-400 hover:underline underline-offset-4"
                    >
                        Read the full case
                        <svg className="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" strokeWidth="2" aria-hidden="true">
                            <path strokeLinecap="round" strokeLinejoin="round" d="M13 7l5 5-5 5M6 12h12" />
                        </svg>
                    </Link>
                </div>
            </div>
        </section>
    );
}


/* ── Demos ───────────────────────────────────────────────────────── */

const DEMOS = [
    { name: 'Flux',   tagline: 'SaaS analytics',   href: 'https://flux.pyxle.app',   kind: 'chart',   gradient: 'from-indigo-500 to-purple-600' },
    { name: 'Chroma', tagline: 'Color palette',    href: 'https://chroma.pyxle.app', kind: 'palette', gradient: 'from-pink-500 to-orange-400' },
    { name: 'Glyph',  tagline: 'Generative art',   href: 'https://glyph.pyxle.app',  kind: 'spiro',   gradient: 'from-violet-500 to-cyan-400' },
];

function DemoPreview({ kind, gradient }) {
    if (kind === 'palette') {
        return (
            <div className="flex h-24 w-full" aria-hidden="true">
                {['#FF6B6B', '#FF8E72', '#FFA45B', '#FFD166', '#F4E285'].map((c, i) => (
                    <div key={i} className="flex-1" style={{ backgroundColor: c }} />
                ))}
            </div>
        );
    }
    if (kind === 'chart') {
        const heights = [42, 58, 66, 54, 78, 72, 90];
        return (
            <div className="flex h-24 w-full items-end gap-1 bg-[#0e0f14] px-4 py-3" aria-hidden="true">
                {heights.map((h, i) => (
                    <div
                        key={i}
                        className={`flex-1 rounded-t bg-gradient-to-t ${gradient}`}
                        style={{ height: `${h}%`, opacity: 0.55 + (i / heights.length) * 0.45 }}
                    />
                ))}
            </div>
        );
    }
    // spiro
    const spiroPath = Array.from({ length: 720 }, (_, i) => {
        const t = (i * Math.PI) / 40;
        const R = 45, r = 13, d = 28;
        const x = (R - r) * Math.cos(t) + d * Math.cos(((R - r) * t) / r);
        const y = (R - r) * Math.sin(t) - d * Math.sin(((R - r) * t) / r);
        return `${i === 0 ? 'M' : 'L'} ${x.toFixed(1)} ${y.toFixed(1)}`;
    }).join(' ');
    return (
        <div className="h-24 w-full bg-[#08080c] flex items-center justify-center" aria-hidden="true">
            <svg viewBox="0 0 120 120" className="h-full w-auto py-1" role="img" aria-label="">
                <defs>
                    <linearGradient id="spiro-grad" x1="0" y1="0" x2="1" y2="1">
                        <stop offset="0%" stopColor="#a78bfa" />
                        <stop offset="100%" stopColor="#22d3ee" />
                    </linearGradient>
                </defs>
                <g transform="translate(60,60)" fill="none" stroke="url(#spiro-grad)" strokeWidth="0.7">
                    <path d={spiroPath} />
                </g>
            </svg>
        </div>
    );
}

function Demos() {
    return (
        <section className="relative px-5 sm:px-6 py-16 sm:py-20">
            <div className="mx-auto max-w-6xl">
                <div data-reveal className="flex flex-col items-start justify-between gap-4 sm:flex-row sm:items-end mb-8">
                    <div>
                        <p className="text-xs font-semibold uppercase tracking-[0.18em] text-emerald-700 dark:text-emerald-400">Showcase</p>
                        <h2 className="mt-3 text-balance text-3xl sm:text-4xl font-semibold tracking-tight">Apps built with Pyxle.</h2>
                    </div>
                    <a
                        href="https://github.com/pyxle-dev/pyxle-demos"
                        target="_blank"
                        rel="noreferrer"
                        className="focus-ring inline-flex items-center gap-1.5 text-sm font-medium text-emerald-700 dark:text-emerald-400 hover:underline underline-offset-4"
                    >
                        Source on GitHub
                        <svg className="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" strokeWidth="2" aria-hidden="true">
                            <path strokeLinecap="round" strokeLinejoin="round" d="M13 7l5 5-5 5M6 12h12" />
                        </svg>
                    </a>
                </div>

                <div className="grid gap-3 sm:gap-4 md:grid-cols-3">
                    {DEMOS.map((d, i) => (
                        <a
                            key={d.name}
                            href={d.href}
                            target="_blank"
                            rel="noreferrer"
                            data-reveal
                            className="focus-ring group flex flex-col overflow-hidden rounded-2xl border transition-all duration-300 border-zinc-200 bg-white hover:-translate-y-0.5 hover:border-zinc-300 hover:shadow-lg hover:shadow-zinc-900/5 dark:border-white/5 dark:bg-white/[0.02] dark:hover:border-white/10 dark:hover:shadow-black/30"
                            style={{ ['--reveal-delay']: `${i * 90}ms` }}
                        >
                            <DemoPreview kind={d.kind} gradient={d.gradient} />
                            <div className="p-5">
                                <div className="flex items-baseline gap-2">
                                    <h3 className="text-[15px] font-semibold">{d.name}</h3>
                                    <span className="text-xs text-zinc-500 dark:text-zinc-400">{d.tagline}</span>
                                </div>
                                <div className="mt-3 inline-flex items-center gap-1 text-xs font-medium text-emerald-700 dark:text-emerald-400 transition-transform group-hover:translate-x-0.5">
                                    Try it live
                                    <svg className="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" strokeWidth="2" aria-hidden="true">
                                        <path strokeLinecap="round" strokeLinejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
                                    </svg>
                                </div>
                            </div>
                        </a>
                    ))}
                </div>
            </div>
        </section>
    );
}


/* ── Get started + Newsletter (merged) ───────────────────────────── */

const INSTALL_STEPS = [
    { cmd: 'pip install pyxle-framework' },
    { cmd: 'pyxle init my-app && cd my-app' },
    { cmd: 'pyxle install' },
    { cmd: 'pyxle dev' },
];

function GetStarted() {
    const subscribe = useAction('subscribe_newsletter');
    const [email, setEmail] = useState('');
    const [status, setStatus] = useState(null);
    const [message, setMessage] = useState('');

    const handleSubmit = useCallback(async (e) => {
        e.preventDefault();
        setStatus(null);
        setMessage('');
        const result = await subscribe({ email });
        if (result.ok) {
            setStatus('success');
            setMessage(result.message);
            setEmail('');
        } else {
            setStatus('error');
            setMessage(result.error);
        }
    }, [email, subscribe]);

    return (
        <section className="relative overflow-hidden px-5 sm:px-6 py-20 sm:py-28">
            <div aria-hidden="true" className="pointer-events-none absolute inset-0 -z-10">
                <div className="aurora aurora-anim parallax-slow absolute inset-x-0 -bottom-40 h-[560px] opacity-60" />
                <div className="absolute inset-x-0 top-0 h-32 bg-gradient-to-b from-white to-transparent dark:from-[#0a0a0b]" />
            </div>
            <div className="mx-auto max-w-6xl">
                {/* Closing punch */}
                <div data-reveal className="mx-auto mb-14 max-w-2xl text-center">
                    <p className="text-xs font-semibold uppercase tracking-[0.18em] text-emerald-700 dark:text-emerald-400">Start now</p>
                    <h2 className="mt-3 text-balance text-3xl font-semibold tracking-tight sm:text-5xl">
                        Your first feature is <span className="gradient-text">one&nbsp;file</span> away.
                    </h2>
                    <p className="mx-auto mt-4 max-w-lg text-pretty text-sm sm:text-base text-zinc-600 dark:text-zinc-400">
                        Install, scaffold, run — then open a <code className="rounded bg-zinc-100 px-1 text-[0.85em] text-emerald-700 dark:bg-white/10 dark:text-emerald-300">.pyxl</code> and ship. MIT-licensed, open source.
                    </p>
                    <div className="mt-7 flex flex-wrap items-center justify-center gap-3">
                        <Link
                            href="/docs/getting-started/installation"
                            className="focus-ring group inline-flex items-center justify-center gap-2 rounded-lg bg-zinc-900 px-5 py-3 text-sm font-medium text-white transition-colors hover:bg-zinc-800 dark:bg-white dark:text-zinc-900 dark:hover:bg-zinc-200"
                        >
                            Get started
                            <svg className="h-3.5 w-3.5 transition-transform group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" strokeWidth="2.2" aria-hidden="true">
                                <path strokeLinecap="round" strokeLinejoin="round" d="M13 7l5 5-5 5M6 12h12" />
                            </svg>
                        </Link>
                        <a
                            href="https://github.com/pyxle-dev/pyxle"
                            target="_blank"
                            rel="noreferrer"
                            className="focus-ring inline-flex items-center justify-center gap-2 rounded-lg border px-5 py-3 text-sm font-medium border-zinc-200 bg-white text-zinc-800 transition-colors hover:bg-zinc-50 dark:border-white/10 dark:bg-white/5 dark:text-zinc-200 dark:hover:bg-white/10"
                        >
                            <svg className="h-4 w-4 text-amber-500" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                                <path d="M11.48 3.5a.56.56 0 011.04 0l2.09 4.94 5.34.46c.5.04.7.66.32.99l-4.05 3.5 1.21 5.22c.11.49-.42.87-.85.61L12 16.98l-4.59 2.74c-.43.26-.96-.12-.85-.61l1.21-5.22-4.05-3.5a.56.56 0 01.32-.99l5.34-.46L11.48 3.5z" />
                            </svg>
                            Star on GitHub
                        </a>
                    </div>
                </div>

                <div className="grid gap-10 lg:grid-cols-2 lg:gap-14">
                    {/* Install steps */}
                    <div data-reveal="left">
                        <h3 className="font-mono text-[11px] uppercase tracking-wider text-zinc-500 dark:text-zinc-400">Four commands · start to running</h3>
                        <ol className="mt-6 space-y-2">
                            {INSTALL_STEPS.map((step, i) => (
                                <li
                                    key={step.cmd}
                                    className="flex items-center gap-3 rounded-lg border px-3.5 py-2.5 font-mono text-[13px] border-zinc-200 bg-white dark:border-white/10 dark:bg-white/[0.02]"
                                >
                                    <span className="font-sans text-[11px] font-medium text-zinc-600 dark:text-zinc-400 tabular-nums w-4">{i + 1}</span>
                                    <span className="text-zinc-600 dark:text-zinc-400 select-none">$</span>
                                    <span className="flex-1 truncate text-zinc-800 dark:text-zinc-200">{step.cmd}</span>
                                    <CopyButton text={step.cmd} />
                                </li>
                            ))}
                        </ol>
                        <div className="mt-6 flex flex-wrap gap-2">
                            <Link
                                href="/docs"
                                className="focus-ring inline-flex items-center gap-1.5 rounded-lg border px-3.5 py-2 text-sm font-medium border-zinc-200 bg-white hover:bg-zinc-50 dark:border-white/10 dark:bg-white/5 dark:hover:bg-white/10 transition-colors"
                            >
                                Read the docs
                            </Link>
                            <Link
                                href="/playground"
                                className="focus-ring inline-flex items-center gap-1.5 rounded-lg border px-3.5 py-2 text-sm font-medium border-zinc-200 bg-white hover:bg-zinc-50 dark:border-white/10 dark:bg-white/5 dark:hover:bg-white/10 transition-colors"
                            >
                                Try the playground
                            </Link>
                        </div>
                    </div>

                    {/* Newsletter */}
                    <div data-reveal="right" style={{ ['--reveal-delay']: '100ms' }}>
                        <div className="relative overflow-hidden rounded-xl border p-6 sm:p-7 border-zinc-200 bg-white dark:border-white/10 dark:bg-white/[0.03]">
                            <div
                                aria-hidden="true"
                                className="pointer-events-none absolute -right-20 -top-20 h-56 w-56 rounded-full opacity-40"
                                style={{ background: 'radial-gradient(closest-side, rgba(16,185,129,0.25), transparent 70%)' }}
                            />
                            <div className="relative">
                                <div className="inline-flex items-center gap-2 text-xs font-medium text-zinc-600 dark:text-zinc-400">
                                    <span className="relative flex h-2 w-2" aria-hidden="true">
                                        <span className="absolute inset-0 inline-flex h-full w-full animate-ping rounded-full bg-emerald-400 opacity-60" />
                                        <span className="relative inline-flex h-2 w-2 rounded-full bg-emerald-500" />
                                    </span>
                                    Stay in the loop
                                </div>
                                <h3 className="mt-3 text-xl sm:text-2xl font-semibold tracking-tight">Release notes. Deep dives. No spam.</h3>
                                <p className="mt-2 text-sm text-zinc-600 dark:text-zinc-400">
                                    This form is a live <Link href="/docs/core-concepts/server-actions" className="underline decoration-dotted underline-offset-2 hover:text-emerald-700 dark:hover:text-emerald-400">@action</Link> — powered by Pyxle itself.
                                </p>
                                <form onSubmit={handleSubmit} className="mt-5 flex flex-col gap-2 sm:flex-row">
                                    <label htmlFor="newsletter-email" className="sr-only">Email address</label>
                                    <input
                                        id="newsletter-email"
                                        type="email"
                                        value={email}
                                        onChange={(e) => { setEmail(e.target.value); setStatus(null); }}
                                        placeholder="you@example.com"
                                        required
                                        autoComplete="email"
                                        className="focus-ring w-full rounded-lg border px-3.5 py-2.5 text-sm outline-none placeholder:text-zinc-400 dark:placeholder:text-zinc-600 border-zinc-200 bg-white text-zinc-900 focus:border-emerald-500/50 dark:border-white/10 dark:bg-black/20 dark:text-white"
                                    />
                                    <button
                                        type="submit"
                                        disabled={subscribe.pending}
                                        className="focus-ring shrink-0 rounded-lg bg-emerald-500 px-4 py-2.5 text-sm font-semibold text-zinc-950 hover:bg-emerald-400 disabled:opacity-60 disabled:cursor-not-allowed transition-colors"
                                    >
                                        {subscribe.pending ? 'Subscribing\u2026' : 'Subscribe'}
                                    </button>
                                </form>
                                <div className="mt-3 min-h-[1.25rem] text-sm" aria-live="polite">
                                    {status === 'success' && <p className="text-emerald-700 dark:text-emerald-400">{message}</p>}
                                    {status === 'error'   && <p className="text-red-500 dark:text-red-400">{message}</p>}
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    );
}


/* ── Footer ──────────────────────────────────────────────────────── */

const FOOTER_COLS = [
    { h: 'Product', links: [['Docs', '/docs'], ['Playground', '/playground'], ['Benchmarks', '/benchmarks'], ['FAQ', '/docs/faq']] },
    { h: 'Learn', links: [['Getting started', '/docs/getting-started/installation'], ['Server actions', '/docs/core-concepts/server-actions'], ['For AI agents', '/docs/guides/for-ai-agents']] },
    { h: 'Community', links: [['GitHub', 'https://github.com/pyxle-dev/pyxle', true], ['Issues', 'https://github.com/pyxle-dev/pyxle/issues', true], ['Releases', 'https://github.com/pyxle-dev/pyxle/releases', true]] },
];

function Footer() {
    const linkCls = 'text-sm text-zinc-600 hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-white transition-colors';
    return (
        <footer className="relative border-t border-zinc-200 dark:border-white/5">
            <div aria-hidden="true" className="gradient-edge-static absolute inset-x-0 top-0 h-px opacity-80" />
            <div className="mx-auto max-w-6xl px-5 sm:px-6 py-14">
                <div className="grid gap-10 sm:grid-cols-2 lg:grid-cols-4">
                    <div className="sm:col-span-2 lg:col-span-1">
                        <Link href="/" aria-label="Pyxle home" className="focus-ring inline-flex items-center gap-2 rounded">
                            <img src="/branding/pyxle-mark.svg" alt="" width="28" height="28" className="h-7 w-7" />
                            <span className="text-[15px] font-semibold tracking-tight">Pyxle</span>
                        </Link>
                        <p className="mt-3 max-w-xs text-sm text-zinc-500 dark:text-zinc-400">
                            Python and React in one file. The full-stack framework that gets out of your way.
                        </p>
                        <a
                            href="https://github.com/pyxle-dev/pyxle"
                            target="_blank"
                            rel="noreferrer"
                            aria-label="Pyxle on GitHub"
                            className="focus-ring mt-4 inline-flex h-9 w-9 items-center justify-center rounded-lg border border-zinc-200 bg-white text-zinc-700 transition-colors hover:bg-zinc-50 dark:border-white/10 dark:bg-white/5 dark:text-zinc-300 dark:hover:bg-white/10"
                        >
                            <svg className="h-4 w-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                                <path d="M12 .3a12 12 0 00-3.8 23.4c.6.1.8-.3.8-.6v-2c-3.3.7-4-1.6-4-1.6-.6-1.4-1.4-1.8-1.4-1.8-1-.7.1-.7.1-.7 1.1.1 1.7 1.2 1.7 1.2 1 1.8 2.8 1.3 3.4 1 .1-.8.4-1.3.8-1.6-2.7-.3-5.5-1.3-5.5-6 0-1.3.5-2.4 1.2-3.2-.1-.3-.5-1.5.1-3.2 0 0 1-.3 3.3 1.2a11.5 11.5 0 016 0C17.3 4.7 18.3 5 18.3 5c.7 1.7.2 2.9.1 3.2.8.8 1.2 1.9 1.2 3.2 0 4.6-2.8 5.6-5.5 5.9.4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6A12 12 0 0012 .3" />
                            </svg>
                        </a>
                    </div>

                    {FOOTER_COLS.map((col) => (
                        <div key={col.h}>
                            <h3 className="text-[11px] font-semibold uppercase tracking-wider text-zinc-500 dark:text-zinc-500">{col.h}</h3>
                            <ul className="mt-4 space-y-2.5">
                                {col.links.map(([label, href, ext]) => (
                                    <li key={label}>
                                        {ext
                                            ? <a href={href} target="_blank" rel="noreferrer" className={linkCls}>{label}</a>
                                            : <Link href={href} className={linkCls}>{label}</Link>}
                                    </li>
                                ))}
                            </ul>
                        </div>
                    ))}
                </div>

                <div className="mt-12 flex flex-col items-center justify-between gap-3 border-t border-zinc-200 pt-6 dark:border-white/5 sm:flex-row">
                    <p className="text-xs text-zinc-500 dark:text-zinc-500">Pyxle Framework — MIT licensed · open source.</p>
                    <p className="inline-flex items-center gap-1.5 font-mono text-[11px] text-zinc-400 dark:text-zinc-600">
                        <span className="h-1.5 w-1.5 rounded-full bg-emerald-500" /> built with Pyxle
                    </p>
                </div>
            </div>
        </footer>
    );
}


/* ── Page ────────────────────────────────────────────────────────── */

export const slots = {};
export const createSlots = () => slots;

export default function Page({ data }) {
    const { version } = data;
    useScrollReveal();
    return (
        <>
            <Head>
                <title>Pyxle — Python + React in one file</title>
                <meta name="description" content="The full-stack Python framework. Async server loaders, React UI, and server actions in a single .pyxl file. SSR, file-based routing, zero glue code." />
                <meta name="viewport" content="width=device-width, initial-scale=1" />
                <meta name="theme-color" content="#0a0a0b" />
                <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
                <link rel="alternate icon" href="/favicon.ico" />
                <meta property="og:title" content="Pyxle — Python + React in one file" />
                <meta property="og:description" content="The full-stack Python framework. Python loaders, React UI, server actions — zero glue code." />
                <meta property="og:type" content="website" />
                <meta property="og:url" content="https://pyxle.dev" />
                <meta property="og:image" content="https://pyxle.dev/branding/og-default.png" />
                <meta name="twitter:card" content="summary_large_image" />
                <meta name="twitter:image" content="https://pyxle.dev/branding/og-default.png" />
            </Head>
            <Nav version={version} />
            <main id="main">
                <Hero />
                <Anatomy />
                <Features />
                <Numbers />
                <ForAgents />
                <Demos />
                <GetStarted />
            </main>
            <Footer />
        </>
    );
}
