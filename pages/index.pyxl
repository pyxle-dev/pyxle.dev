                        <div className="absolute inset-0 grid-bg opacity-40" />
                        <div className="aurora aurora-anim absolute -inset-x-10 -top-40 h-[440px] opacity-70" />
                    </div>
                    <div className="relative">
                        <div className="flex flex-col items-start justify-between gap-4 sm:flex-row sm:items-end">
                            <div>
                                <p className="text-xs font-semibold uppercase tracking-[0.18em] text-emerald-400">Performance</p>
