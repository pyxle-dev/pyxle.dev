/* ── Anatomy: one file vs the usual sprawl (the wedge) ───────────── */

const OLD_WAY_FILES = [
    'app/api/users/route.ts',
    'server/users_service.py',
    'db/schema.sql',
    'types/user.d.ts',
    'hooks/use-users.ts',
    'app/users/page.tsx',
    'app/users/loading.tsx',
    'lib/api-client.ts',
];

const USERS_PYXL = `# users.pyxl

@server
async def load(request):
    return {"users": await db.all_users()}

@action
async def add_user(request):
    body = await request.json()
    return {"user": await db.insert(body)}


import React from 'react';
import { useAction } from 'pyxle/client';

export default function Users({ data }) {
    const add = useAction('add_user');
    return <UserTable rows={data.users} onAdd={add} />;
}`;

const ANATOMY_PARTS = [
    { label: '@server', role: 'loads data → props', dot: 'from-amber-400 to-amber-300' },
    { label: '@action', role: 'mutates on the server', dot: 'from-emerald-400 to-cyan-400' },
    { label: 'React', role: 'renders the UI', dot: 'from-cyan-400 to-blue-400' },
];

function Anatomy() {
    return (
        <section className="relative overflow-hidden px-5 sm:px-6 py-20 sm:py-28">
