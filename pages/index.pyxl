                            <Link
                                href="/benchmarks"
                                className="focus-ring inline-flex items-center gap-1.5 rounded-lg border border-white/10 bg-white/5 px-3.5 py-2 text-sm font-medium text-emerald-400 transition-colors hover:bg-white/10"
                            >
