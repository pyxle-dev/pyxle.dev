                                            <span className="h-2.5 w-2.5 rounded-full bg-zinc-600/40" />
                                        </span>
                                        <span className="ml-1 font-mono text-[11px] text-zinc-400">users.pyxl</span>
                                        <span className="ml-auto rounded-full border border-emerald-500/25 bg-emerald-500/10 px-2 py-0.5 font-mono text-[10px] text-emerald-300">1 file</span>
