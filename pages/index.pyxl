}


/* ── 05 · For the agents ─────────────────────────────────────────── */

function ContextStrip() {
    /* One continuous stroke vs. eight broken segments — context per
       feature read, in one glance. */
    const segs = Array.from({ length: 8 }, (_, i) => 10 + i * 36);
    return (
        <figure data-reveal className="mt-8" style={{ ['--reveal-delay']: '120ms' }}>
            <div className="space-y-5 border-y border-rule py-6">
                <div className="flex items-center gap-4">
                    <span className="w-36 shrink-0 font-mono text-[11px] text-ink">pyxle — one file</span>
                    <svg viewBox="0 0 310 16" className="h-4 min-w-0 flex-1" preserveAspectRatio="none" aria-hidden="true">
                        <path d="M4 9 C 80 4, 200 13, 288 7" pathLength="1" className="gp-draw" style={{ ['--draw-dur']: '700ms' }} fill="none" stroke="var(--c-accent)" strokeWidth="3.5" strokeLinecap="round" />
                        <circle cx="299" cy="7" r="4" className="gp-dot" style={{ ['--dot-delay']: '700ms' }} fill="var(--c-accent)" />
                    </svg>
                </div>
                <div className="flex items-center gap-4">
                    <span className="w-36 shrink-0 font-mono text-[11px] text-ink2">typical stack — 8 files</span>
                    <svg viewBox="0 0 310 16" className="h-4 min-w-0 flex-1" preserveAspectRatio="none" aria-hidden="true">
                        {segs.map((x) => (
                            <path key={x} d={`M${x} 8 H${x + 24}`} stroke="var(--c-ink2)" strokeOpacity="0.45" strokeWidth="3.5" strokeLinecap="round" vectorEffect="non-scaling-stroke" fill="none" />
                        ))}
                    </svg>
                </div>
            </div>
            <figcaption className="mt-3 font-mono text-xs text-ink2">Fig. 4 — context per feature read.</figcaption>
        </figure>
    );
}

function ForAgents() {
    return (
        <GpSection n="05" id="agents">
            <div className="grid gap-12 lg:grid-cols-12">
                <div className="order-2 min-w-0 lg:order-1 lg:col-span-6">
                    <div data-reveal style={{ ['--reveal-delay']: '100ms' }}>
                        <Plate
                            label="terminal"
                            caption={<>Fig. 3 — <span className="text-ink">pyxle check</span>, verbatim. Structured diagnostics, an exit code an agent can branch on.</>}
                        >
                            {/* A real transcript — reproduce it by running
                               `pyxle check` on a project with these two bugs. */}
                            <pre className="duotone overflow-x-auto p-5 font-mono text-[12.5px] leading-[1.9]">
                                <code>
                                    <span className="sh-cmd">$</span> <span className="sh-fn">pyxle check</span>{'\n'}
                                    <span className="sh-cmt">ℹ️  Checked 2 .pyxl file(s) in my-app/</span>{'\n'}
                                    {'  error: '}<span className="sh-kw">[python]</span> line 2: <span className="sh-str">expected ':'</span>{'\n'}
                                    <span className="sh-cmt">    --&gt; pages/feed.pyxl</span>{'\n'}
                                    {'  error: '}<span className="sh-kw">[jsx]</span> line 6: <span className="sh-str">JSX syntax error: Adjacent JSX elements must be wrapped in an enclosing tag. Did you want a JSX fragment &lt;&gt;...&lt;/&gt;? (6:8)</span>{'\n'}
                                    <span className="sh-cmt">    --&gt; pages/likes.pyxl</span>{'\n'}
                                    ❌ Check failed with 2 error(s){'\n'}
                                    <span className="sh-cmd">$</span> <span className="sh-fn">echo $?</span>{'\n'}
                                    1
                                </code>
                            </pre>
                        </Plate>
                    </div>
                    <ContextStrip />
                </div>

                <div className="order-1 min-w-0 lg:order-2 lg:col-span-6">
                    <GpHead
                        n="05"
                        eyebrow="For the agents"
                        title="One file is also how an agent reads."
                        lead="Context windows are budgets. A Pyxle feature is one read — loader, mutations, and UI in a single pass, not a scavenger hunt across eight files before the first edit."
                    />
                    <div data-reveal="none" className="my-9 max-w-xl">
                        <span className="gp-rule-x block h-px bg-rule" aria-hidden="true" />
                        <p className="py-5 font-display text-[1.5rem] font-[460] leading-snug tracking-[-0.01em] text-ink sm:text-[1.75rem]">
                            “One read = the whole feature.”
                        </p>
                        <span className="gp-rule-x block h-px bg-rule" style={{ ['--rule-delay']: '120ms' }} aria-hidden="true" />
                    </div>
                    <p data-reveal className="max-w-[58ch] text-pretty text-base leading-[1.7] text-ink2">
                        <code className="text-[0.9em] text-acct">pyxle check</code> emits structured,
                        grep-able diagnostics — section, line, message, file — with an exit code an
                        agent can branch on. And it is all Python — the language models write best.
                    </p>
                    <p data-reveal className="mt-7">
                        <EditorialLink href="/docs/guides/for-ai-agents">Read the full case →</EditorialLink>
                    </p>
                </div>
            </div>
        </GpSection>
    );
}


/* ── 06 · As Markdown (readable by machines) ─────────────────────── */

function ReadableAsMarkdown() {
    return (
        <GpSection n="06" id="markdown">
            <div className="grid gap-12 lg:grid-cols-12">
                <div className="order-1 min-w-0 lg:col-span-6">
                    <GpHead
                        n="06"
                        eyebrow="Markdown, built in"
                        title="Every page is also Markdown."
                        lead="Your readers increasingly arrive with an AI in the loop — and it wants text, not your HTML. Flip one flag and every page serves a clean Markdown twin: append .md to any URL, or send Accept: text/markdown. This page included."
                    />
                    <div data-reveal="none" className="my-9 max-w-xl">
                        <span className="gp-rule-x block h-px bg-rule" aria-hidden="true" />
                        <p className="py-5 font-display text-[1.5rem] font-[460] leading-snug tracking-[-0.01em] text-ink sm:text-[1.75rem]">
                            “Append{' '}
                            <code className="font-mono text-[0.82em] text-acct">.md</code>. Read the page.”
                        </p>
                        <span className="gp-rule-x block h-px bg-rule" style={{ ['--rule-delay']: '120ms' }} aria-hidden="true" />
                    </div>
                    <p data-reveal className="max-w-[58ch] text-pretty text-base leading-[1.7] text-ink2">
                        You decide where each page's Markdown comes from — a co-located{' '}
                        <code className="text-[0.9em] text-acct">.md</code> file, a{' '}
                        <code className="text-[0.9em] text-acct">to_markdown</code> handler, or one{' '}
                        <code className="text-[0.9em] text-acct">llms.py</code> for a whole section. An{' '}
                        <code className="text-[0.9em] text-acct">llms.txt</code> index and discovery
                        headers come free — it is how a developer pastes your docs into Claude or
                        Cursor and gets clean context, not tag soup.
                    </p>
                    <p data-reveal className="mt-7">
                        <EditorialLink href="/docs/guides/llms">How it works →</EditorialLink>
                    </p>
                </div>

                <div className="order-2 min-w-0 lg:col-span-6">
                    <div data-reveal style={{ ['--reveal-delay']: '100ms' }}>
                        <Plate
                            label="terminal"
                            caption={<>Fig. 5 — any URL, plus <span className="text-ink">.md</span>. Turned on with one line: <span className="text-ink">"llms": true</span>.</>}
                        >
                            <pre className="duotone overflow-x-auto p-5 font-mono text-[12.5px] leading-[1.9]">
                                <code>
                                    <span className="sh-cmd">$</span> <span className="sh-fn">curl</span> pyxle.dev/docs/routing<span className="sh-kw">.md</span>{'\n'}
                                    <span className="sh-cmt">&gt; Markdown rendition of /docs/routing,</span>{'\n'}
                                    <span className="sh-cmt">&gt; served for agents. Index: /llms.txt</span>{'\n'}
                                    {'\n'}
                                    <span className="sh-kw"># Routing</span>{'\n'}
                                    {'\n'}
                                    {'Pyxle uses '}<span className="sh-str">**file-based routing**</span>{'. The'}{'\n'}
                                    {'structure of your '}<span className="sh-str">`pages/`</span>{' directory is'}{'\n'}
                                    {'your URL routes — no router config,'}{'\n'}
                                    {'no tag soup, just the words.'}
                                </code>
                            </pre>
                        </Plate>
                    </div>
                </div>
            </div>
        </GpSection>
    );
}


/* ── 07 · In the wild (live specimens) ───────────────────────────── */

const DEMOS = [
    { name: 'Flux', tagline: 'SaaS analytics', href: 'https://flux.pyxle.app', kind: 'chart' },
    { name: 'Chroma', tagline: 'Color palette', href: 'https://chroma.pyxle.app', kind: 'palette' },
    { name: 'Glyph', tagline: 'Generative art', href: 'https://glyph.pyxle.app', kind: 'spiro' },
];

/* Miniature of each app — a photograph of the real thing, so the
   specimens keep their own colors inside the plate frame. */
function DemoPreview({ kind }) {
    if (kind === 'palette') {
        return (
            <div className="flex h-28 w-full" aria-hidden="true">
                {['#FF6B6B', '#FF8E72', '#FFA45B', '#FFD166', '#F4E285'].map((c, i) => (
                    <div key={i} className="flex-1" style={{ backgroundColor: c }} />
                ))}
            </div>
        );
    }
    if (kind === 'chart') {
        const heights = [42, 58, 66, 54, 78, 72, 90];
        return (
            <div className="flex h-28 w-full items-end gap-1 bg-[#0e0f14] px-4 py-3" aria-hidden="true">
                {heights.map((h, i) => (
                    <div
                        key={i}
                        className="flex-1 rounded-t bg-gradient-to-t from-indigo-500 to-purple-600"
                        style={{ height: `${h}%`, opacity: 0.55 + (i / heights.length) * 0.45 }}
                    />
                ))}
            </div>
        );
    }
    // spiro — a deterministic spirograph, drawn server-side
    const spiroPath = Array.from({ length: 720 }, (_, i) => {
        const t = (i * Math.PI) / 40;
        const R = 45, r = 13, d = 28;
        const x = (R - r) * Math.cos(t) + d * Math.cos(((R - r) * t) / r);
        const y = (R - r) * Math.sin(t) - d * Math.sin(((R - r) * t) / r);
        return `${i === 0 ? 'M' : 'L'} ${x.toFixed(1)} ${y.toFixed(1)}`;
    }).join(' ');
    return (
        <div className="flex h-28 w-full items-center justify-center bg-[#08080c]" aria-hidden="true">
            <svg viewBox="-90 -90 180 180" className="h-full w-auto py-1.5">
                <path d={spiroPath} fill="none" stroke="#22d3ee" strokeWidth="1" opacity="0.8" />
            </svg>
        </div>
    );
}

