from pyxle import __version__
from pyxle.runtime import ActionError

VALID_EMOJIS = ["heart", "fire", "mind_blown", "rocket", "sparkles", "clap"]


@server
async def load_playground(request):
    from db import get_reactions, increment_playground_views

    views = await increment_playground_views()
    reactions = await get_reactions()

    return {
        "totalViews": views,
        "reactions": reactions,
        "version": __version__,
    }


@action
async def react_emoji(request):
    from db import check_rate_limit, get_client_ip, increment_reaction

    client_ip = get_client_ip(request)
    # 5 reactions per hour per IP, scoped to the playground reactions board.
    if not await check_rate_limit(client_ip, scope="react_emoji"):
        raise ActionError(
            "Rate limit reached. Please try again after 1 hour.",
            status_code=429,
        )

    body = await request.json()
    emoji = body.get("emoji", "")
    if emoji not in VALID_EMOJIS:
        raise ActionError("Invalid reaction", status_code=400)

    new_count = await increment_reaction(emoji)
    return {"ok": True, "emoji": emoji, "count": new_count}


import React, { useState } from 'react';
import { useAction, Head } from 'pyxle/client';
import { LivePlayground, DEFAULT_SOURCE } from './components/live-playground.jsx';
import {
    useScrollReveal, CopyButton, CodeBlock,
    InkButton, EditorialLink, Plate, GpSection, GpHead, GalleyFooter,
} from './components/galley.jsx';

