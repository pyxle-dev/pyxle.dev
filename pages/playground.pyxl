                </p>
            </div>
        </section>
    );
}


/* ── Real-server proof: @action → SQLite (live, shared) ───────────── */

const EMOJI_MAP = {
    heart: { icon: '❤️', label: 'Love' },
    fire: { icon: '🔥', label: 'Fire' },
    mind_blown: { icon: '🤯', label: 'Mind-blown' },
    rocket: { icon: '🚀', label: 'Rocket' },
    sparkles: { icon: '✨', label: 'Sparkles' },
    clap: { icon: '👏', label: 'Clap' },
};

const REACTION_CODE = `@action
async def react_emoji(request):
    body = await request.json()
    emoji = body.get("emoji", "")
    if emoji not in VALID_EMOJIS:
        raise ActionError("Invalid reaction")

    count = increment_reaction(emoji)
    return {"ok": True, "emoji": emoji, "count": count}`;

function ReactionBoard({ data }) {
    const react = useAction('react_emoji');
    const [counts, setCounts] = useState(data.reactions || {});
    const [latency, setLatency] = useState({});
    const [error, setError] = useState('');

    const handleClick = async (emoji) => {
        setCounts((p) => ({ ...p, [emoji]: (p[emoji] || 0) + 1 })); // optimistic
        const t0 = performance.now();
        const r = await react({ emoji });
        const ms = Math.round(performance.now() - t0);
        if (r.ok) {
            setCounts((p) => ({ ...p, [r.emoji]: r.count }));
            setLatency((p) => ({ ...p, [emoji]: ms }));
            setError('');
            setTimeout(() => setLatency((p) => { const n = { ...p }; delete n[emoji]; return n; }), 2000);
        } else {
            setCounts((p) => ({ ...p, [emoji]: Math.max(0, (p[emoji] || 1) - 1) }));
            setError(r.error || 'Something went wrong.');
        }
    };

    const total = Object.values(counts).reduce((a, b) => a + b, 0);

    return (
        <section className="relative px-5 sm:px-6 py-16 sm:py-20">
            <div className="mx-auto max-w-6xl">
                <div data-reveal className="mb-10 text-center">
                    <p className="text-xs font-semibold uppercase tracking-[0.18em] text-emerald-700 dark:text-emerald-400">And on a real server</p>
                    <h2 className="mt-3 text-balance text-3xl sm:text-4xl font-semibold tracking-tight mx-auto max-w-2xl">The same <span className="gradient-text">@action</span>, hitting a real database.</h2>
                    <p className="mx-auto mt-4 max-w-xl text-pretty text-sm sm:text-base text-zinc-600 dark:text-zinc-400">
                        The editor above runs client-side. This board is the real deploy — every click is a POST to Python, writing to SQLite. The counts are live and shared by everyone on this page right now.
                    </p>
                </div>

                <div className="grid items-stretch gap-5 lg:grid-cols-2 lg:gap-6">
                    <div data-reveal="left" className="flex">
                        <div className="flex flex-1 flex-col rounded-2xl border p-6 sm:p-7 border-zinc-200 bg-white dark:border-white/10 dark:bg-white/[0.02]">
                            <div className="mb-5 flex items-center justify-between">
                                <h3 className="text-base font-semibold">React to this page</h3>
                                <span className="font-mono text-sm tabular-nums text-zinc-500 dark:text-zinc-400">{total} total</span>
                            </div>
                            <div className="grid grid-cols-3 gap-3">
                                {Object.entries(EMOJI_MAP).map(([key, { icon, label }]) => (
                                    <button key={key} onClick={() => handleClick(key)}
                                        className="focus-ring relative flex flex-col items-center gap-1.5 rounded-xl border p-3.5 transition-all hover:-translate-y-0.5 border-zinc-200 bg-white hover:border-emerald-500/30 hover:bg-emerald-50/50 dark:border-white/10 dark:bg-white/[0.02] dark:hover:border-emerald-500/30 dark:hover:bg-emerald-500/[0.05]">
                                        <span className="text-2xl select-none">{icon}</span>
                                        <span className="text-[11px] text-zinc-500 dark:text-zinc-400">{label}</span>
                                        <span className="font-mono text-sm font-semibold tabular-nums text-zinc-700 dark:text-zinc-300">{counts[key] || 0}</span>
                                        {latency[key] != null && (
                                            <span className="absolute -right-2 -top-2 rounded-full bg-emerald-500 px-1.5 py-0.5 font-mono text-[10px] text-zinc-950">{latency[key]}ms</span>
                                        )}
                                    </button>
                                ))}
                            </div>
                            {error && <p className="mt-4 text-sm font-medium text-red-500" role="alert">{error}</p>}
                            <p className="mt-auto pt-6 text-xs text-zinc-500 dark:text-zinc-400">Every click is a POST to Python — no API route, no glue.</p>
                        </div>
                    </div>

                    <div data-reveal="right" className="flex" style={{ ['--reveal-delay']: '100ms' }}>
                        <div className="flex flex-1 flex-col overflow-hidden rounded-2xl border border-white/10 bg-[#0b0b0d]">
                            <div className="flex items-center gap-2 border-b border-white/5 px-4 py-2.5">
                                <span className="flex gap-1.5" aria-hidden="true">
                                    <span className="h-2.5 w-2.5 rounded-full bg-zinc-600/80" />
                                    <span className="h-2.5 w-2.5 rounded-full bg-zinc-600/60" />
                                    <span className="h-2.5 w-2.5 rounded-full bg-zinc-600/40" />
                                </span>
                                <span className="ml-1 font-mono text-[11px] text-zinc-400">pages/playground.pyxl</span>
                            </div>
                            <CodeBlock code={REACTION_CODE} className="flex-1 p-5 text-[12.5px] text-zinc-300" />
                        </div>
                    </div>
                </div>
            </div>
        </section>
    );
}


/* ── Closing CTA ──────────────────────────────────────────────────── */

const INSTALL_STEPS = ['pip install pyxle-framework', 'pyxle init my-app && cd my-app', 'pyxle install', 'pyxle dev'];

function CTASection() {
    return (
        <section className="relative overflow-hidden px-5 sm:px-6 py-20 sm:py-28">
            <div aria-hidden="true" className="pointer-events-none absolute inset-0 -z-10">
                <div className="aurora aurora-anim parallax-slow absolute inset-x-0 -bottom-40 h-[520px] opacity-60" />
            </div>
            <div className="mx-auto max-w-3xl text-center">
                <div data-reveal>
                    <p className="text-xs font-semibold uppercase tracking-[0.18em] text-emerald-700 dark:text-emerald-400">Ready when you are</p>
                    <h2 className="mt-3 text-balance text-3xl font-semibold tracking-tight sm:text-5xl">Like what you ran? <span className="gradient-text">Build it for real.</span></h2>
                    <p className="mx-auto mt-4 max-w-lg text-pretty text-sm sm:text-base text-zinc-600 dark:text-zinc-400">Four commands from zero to a running dev server.</p>
                </div>
                <div data-reveal className="mx-auto mt-8 max-w-md space-y-2 text-left" style={{ ['--reveal-delay']: '80ms' }}>
                    {INSTALL_STEPS.map((cmd, i) => (
                        <div key={cmd} className="flex items-center gap-3 rounded-lg border px-3.5 py-2.5 font-mono text-[13px] border-zinc-200 bg-white dark:border-white/10 dark:bg-white/[0.02]">
                            <span className="w-4 font-sans text-[11px] font-medium tabular-nums text-zinc-500 dark:text-zinc-400">{i + 1}</span>
                            <span className="select-none text-zinc-500 dark:text-zinc-400">$</span>
                            <span className="flex-1 truncate text-zinc-800 dark:text-zinc-200">{cmd}</span>
                            <CopyButton text={cmd} />
                        </div>
                    ))}
                </div>
                <div data-reveal className="mt-7 flex flex-wrap items-center justify-center gap-3" style={{ ['--reveal-delay']: '160ms' }}>
                    <Link href="/docs/getting-started/installation" className="focus-ring group inline-flex items-center justify-center gap-2 rounded-lg bg-zinc-900 px-5 py-3 text-sm font-medium text-white hover:bg-zinc-800 dark:bg-white dark:text-zinc-900 dark:hover:bg-zinc-200 transition-colors">
                        Read the docs
                        <svg className="h-3.5 w-3.5 transition-transform group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" strokeWidth="2.2" aria-hidden="true"><path strokeLinecap="round" strokeLinejoin="round" d="M13 7l5 5-5 5M6 12h12" /></svg>
                    </Link>
                    <a href="https://github.com/pyxle-dev/pyxle" target="_blank" rel="noreferrer" className="focus-ring inline-flex items-center justify-center gap-2 rounded-lg border px-5 py-3 text-sm font-medium border-zinc-200 bg-white text-zinc-800 hover:bg-zinc-50 dark:border-white/10 dark:bg-white/5 dark:text-zinc-200 dark:hover:bg-white/10 transition-colors">
                        <svg className="h-4 w-4 text-amber-500" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M11.48 3.5a.56.56 0 011.04 0l2.09 4.94 5.34.46c.5.04.7.66.32.99l-4.05 3.5 1.21 5.22c.11.49-.42.87-.85.61L12 16.98l-4.59 2.74c-.43.26-.96-.12-.85-.61l1.21-5.22-4.05-3.5a.56.56 0 01.32-.99l5.34-.46L11.48 3.5z" /></svg>
                        Star on GitHub
                    </a>
                </div>
            </div>
        </section>
    );
}


/* ── Footer ───────────────────────────────────────────────────────── */
const FOOTER_COLS = [
    { h: 'Product', links: [['Docs', '/docs'], ['Playground', '/playground'], ['Benchmarks', '/benchmarks'], ['FAQ', '/docs/faq']] },
    { h: 'Learn', links: [['Getting started', '/docs/getting-started/installation'], ['Server actions', '/docs/core-concepts/server-actions'], ['For AI agents', '/docs/guides/for-ai-agents']] },
    { h: 'Community', links: [['GitHub', 'https://github.com/pyxle-dev/pyxle', true], ['Issues', 'https://github.com/pyxle-dev/pyxle/issues', true], ['Releases', 'https://github.com/pyxle-dev/pyxle/releases', true]] },
];

function Footer() {
    const linkCls = 'text-sm text-zinc-600 hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-white transition-colors';
    return (
        <footer className="relative border-t border-zinc-200 dark:border-white/5">
            <div aria-hidden="true" className="gradient-edge-static absolute inset-x-0 top-0 h-px opacity-80" />
            <div className="mx-auto max-w-6xl px-5 sm:px-6 py-14">
                <div className="grid gap-10 sm:grid-cols-2 lg:grid-cols-4">
                    <div className="sm:col-span-2 lg:col-span-1">
                        <Link href="/" aria-label="Pyxle home" className="focus-ring inline-flex items-center gap-2 rounded">
                            <img src="/branding/pyxle-mark.svg" alt="" width="28" height="28" className="h-7 w-7" />
                            <span className="text-[15px] font-semibold tracking-tight">Pyxle</span>
                        </Link>
                        <p className="mt-3 max-w-xs text-sm text-zinc-500 dark:text-zinc-400">Python and React in one file. The full-stack framework that gets out of your way.</p>
                    </div>
                    {FOOTER_COLS.map((col) => (
                        <div key={col.h}>
                            <h3 className="text-[11px] font-semibold uppercase tracking-wider text-zinc-500 dark:text-zinc-500">{col.h}</h3>
                            <ul className="mt-4 space-y-2.5">
                                {col.links.map(([label, href, ext]) => (
                                    <li key={label}>{ext ? <a href={href} target="_blank" rel="noreferrer" className={linkCls}>{label}</a> : <Link href={href} className={linkCls}>{label}</Link>}</li>
                                ))}
                            </ul>
                        </div>
                    ))}
                </div>
                <div className="mt-12 flex flex-col items-center justify-between gap-3 border-t border-zinc-200 pt-6 dark:border-white/5 sm:flex-row">
                    <p className="text-xs text-zinc-500 dark:text-zinc-500">Pyxle Framework — MIT licensed · open source.</p>
                    <p className="inline-flex items-center gap-1.5 font-mono text-[11px] text-zinc-400 dark:text-zinc-600"><span className="h-1.5 w-1.5 rounded-full bg-emerald-500" /> built with Pyxle</p>
                </div>
            </div>
        </footer>
    );
}


/* ── Page ─────────────────────────────────────────────────────────── */
export default function PlaygroundPage({ data }) {
    useScrollReveal();
    return (
        <>
            <Head>
                <title>Playground — Try Pyxle with zero install</title>
                <meta name="description" content="Try Pyxle with zero install: write a real .pyxl and run it in an isolated in-browser sandbox. The same @server and @action code runs server-side in a real app." />
                <meta name="viewport" content="width=device-width, initial-scale=1" />
                <meta name="theme-color" content="#0a0a0b" />
                <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
                <meta property="og:title" content="Pyxle Playground — try it with zero install" />
                <meta property="og:description" content="Write and run real Pyxle in an isolated sandbox — zero install. Real apps run this Python server-side." />
                <meta property="og:type" content="website" />
                <meta property="og:url" content="https://pyxle.dev/playground" />
                <meta property="og:image" content="https://pyxle.dev/branding/og-default.png" />
                <meta name="twitter:card" content="summary_large_image" />
                <meta name="twitter:image" content="https://pyxle.dev/branding/og-default.png" />
            </Head>
            <Nav version={data.version} />
            <main id="main">
                <Repl />
                <ReactionBoard data={data} />
                <CTASection />
            </main>
            <Footer />
        </>
    );
}
