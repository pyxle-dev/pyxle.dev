from pyxle import __version__
from pyxle.runtime import ActionError

VALID_EMOJIS = ["heart", "fire", "mind_blown", "rocket", "sparkles", "clap"]


@server
async def load_playground(request):
    from db import get_reactions, increment_playground_views

    views = increment_playground_views()
    reactions = get_reactions()

    return {
        "totalViews": views,
        "reactions": reactions,
        "version": __version__,
    }


@action
async def react_emoji(request):
    from db import check_rate_limit, get_client_ip, increment_reaction

    client_ip = get_client_ip(request)
    # 5 reactions per hour per IP, scoped to the playground reactions board.
    if not check_rate_limit(client_ip, scope="react_emoji"):
        raise ActionError(
            "Rate limit reached. Please try again after 1 hour.",
            status_code=429,
        )

    body = await request.json()
    emoji = body.get("emoji", "")
    if emoji not in VALID_EMOJIS:
        raise ActionError("Invalid reaction", status_code=400)

    new_count = increment_reaction(emoji)
    return {"ok": True, "emoji": emoji, "count": new_count}


import React, { useState, useEffect } from 'react';
import { useAction, Link, Head } from 'pyxle/client';
import { LivePlayground } from './components/live-playground.jsx';
import { tokenizeBlock } from './components/code-highlighter.jsx';
import { ThemeToggle } from './components/theme-toggle.jsx';

export const slots = {};
export const createSlots = () => slots;


/* ── Scroll reveal (native IntersectionObserver, no-JS safe) ──────── */
function useScrollReveal() {
    useEffect(() => {
        if (typeof window === 'undefined') return;
        const els = Array.from(document.querySelectorAll('[data-reveal]'));
        const reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        if (reduce || !('IntersectionObserver' in window)) {
            els.forEach((el) => el.classList.add('is-visible'));
            return;
        }
        const io = new IntersectionObserver((entries) => {
            for (const e of entries) {
                if (e.isIntersecting) { e.target.classList.add('is-visible'); io.unobserve(e.target); }
            }
        }, { rootMargin: '0px 0px -10% 0px', threshold: 0.12 });
        els.forEach((el) => io.observe(el));
        return () => io.disconnect();
    }, []);
}

function CopyButton({ text, label = 'Copy' }) {
    const [copied, setCopied] = useState(false);
    const copy = () => {
        if (typeof navigator !== 'undefined' && navigator.clipboard) {
            navigator.clipboard.writeText(text);
            setCopied(true);
            setTimeout(() => setCopied(false), 1600);
        }
    };
    return (
        <button type="button" onClick={copy} aria-label={`${label} to clipboard`}
            className="focus-ring inline-flex items-center gap-1.5 rounded-md border px-2 py-1 text-[11px] font-medium transition border-zinc-200 bg-white text-zinc-500 hover:bg-zinc-50 hover:text-zinc-900 dark:border-white/10 dark:bg-white/5 dark:text-zinc-400 dark:hover:bg-white/10 dark:hover:text-white">
            {copied ? 'Copied' : label}
        </button>
    );
}

function CodeBlock({ code, lang = 'pyxl', className = '' }) {
    return (
        <pre className={`overflow-x-auto font-mono leading-[1.7] ${className}`}>
            <code>
                {tokenizeBlock(code, lang).map((tokens, i) => (
                    <React.Fragment key={i}>
                        {tokens.length === 0 ? '\n' : (<>{tokens.map((t, j) => <span key={j} className={t.cls}>{t.text}</span>)}{'\n'}</>)}
                    </React.Fragment>
                ))}
            </code>
        </pre>
    );
}


/* ── Nav ─────────────────────────────────────────────────────────── */
function Nav({ version }) {
    const [scrolled, setScrolled] = useState(false);
    const [open, setOpen] = useState(false);
    useEffect(() => {
        const onScroll = () => setScrolled(window.scrollY > 8);
        onScroll();
        window.addEventListener('scroll', onScroll, { passive: true });
        return () => window.removeEventListener('scroll', onScroll);
    }, []);
    const linkCls = 'text-sm text-zinc-600 hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-white transition-colors';
    return (
        <header className={`fixed inset-x-0 top-0 z-50 transition-colors duration-200 ${scrolled ? 'bg-white/70 dark:bg-[#0a0a0b]/70 backdrop-blur-xl border-b border-zinc-200/70 dark:border-white/5' : 'border-b border-transparent'}`}>
            <nav className="mx-auto flex h-14 max-w-6xl items-center justify-between px-5 sm:px-6">
                <div className="flex items-center gap-3">
                    <Link href="/" aria-label="Pyxle home" className="flex items-center gap-2 focus-ring rounded">
                        <img src="/branding/pyxle-mark.svg" alt="" width="28" height="28" className="h-7 w-7" />
                        <span className="text-[15px] font-semibold tracking-tight">Pyxle</span>
                    </Link>
                    <span className="hidden xs:inline-flex items-center rounded-full border px-2 py-0.5 font-mono text-[10px] text-zinc-500 border-zinc-200 dark:border-white/10 dark:text-zinc-400">v{version}</span>
                </div>
                <div className="hidden md:flex items-center gap-6">
                    <Link href="/docs" className={linkCls}>Docs</Link>
                    <Link href="/playground" className="text-sm font-medium text-emerald-700 dark:text-emerald-400">Playground</Link>
                    <Link href="/benchmarks" className={linkCls}>Benchmarks</Link>
                </div>
                <div className="flex items-center gap-2">
                    <a href="https://github.com/pyxle-dev/pyxle" target="_blank" rel="noreferrer" aria-label="Pyxle on GitHub"
                        className="focus-ring hidden sm:inline-flex h-9 w-9 items-center justify-center rounded-lg border border-zinc-200 bg-white text-zinc-700 hover:bg-zinc-50 dark:border-white/10 dark:bg-white/5 dark:text-zinc-300 dark:hover:bg-white/10 transition-colors">
                        <svg className="h-4 w-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 .3a12 12 0 00-3.8 23.4c.6.1.8-.3.8-.6v-2c-3.3.7-4-1.6-4-1.6-.6-1.4-1.4-1.8-1.4-1.8-1-.7.1-.7.1-.7 1.1.1 1.7 1.2 1.7 1.2 1 1.8 2.8 1.3 3.4 1 .1-.8.4-1.3.8-1.6-2.7-.3-5.5-1.3-5.5-6 0-1.3.5-2.4 1.2-3.2-.1-.3-.5-1.5.1-3.2 0 0 1-.3 3.3 1.2a11.5 11.5 0 016 0C17.3 4.7 18.3 5 18.3 5c.7 1.7.2 2.9.1 3.2.8.8 1.2 1.9 1.2 3.2 0 4.6-2.8 5.6-5.5 5.9.4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6A12 12 0 0012 .3" /></svg>
                    </a>
                    <ThemeToggle />
                    <button type="button" onClick={() => setOpen(!open)} aria-label="Toggle menu"
                        className="focus-ring md:hidden rounded-lg border p-2 transition border-zinc-200 bg-white text-zinc-600 hover:bg-zinc-50 dark:border-white/10 dark:bg-white/5 dark:text-zinc-400 dark:hover:bg-white/10">
                        <svg className="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" strokeWidth="2" aria-hidden="true">
                            {open ? <path strokeLinecap="round" strokeLinejoin="round" d="M6 18L18 6M6 6l12 12" /> : <path strokeLinecap="round" strokeLinejoin="round" d="M4 7h16M4 12h16M4 17h16" />}
                        </svg>
                    </button>
                </div>
            </nav>
            {open && (
                <div className="md:hidden border-t border-zinc-200/70 dark:border-white/5 bg-white/95 dark:bg-[#0a0a0b]/95 backdrop-blur-xl">
                    <div className="mx-auto flex max-w-6xl flex-col gap-1 px-5 py-3">
                        <Link href="/docs" onClick={() => setOpen(false)} className="py-2 text-sm text-zinc-700 dark:text-zinc-300">Docs</Link>
                        <Link href="/benchmarks" onClick={() => setOpen(false)} className="py-2 text-sm text-zinc-700 dark:text-zinc-300">Benchmarks</Link>
                        <a href="https://github.com/pyxle-dev/pyxle" target="_blank" rel="noreferrer" className="py-2 text-sm text-zinc-700 dark:text-zinc-300">GitHub</a>
                    </div>
                </div>
            )}
        </header>
    );
}


/* ── Runnable examples (each runs in the isolated in-browser sandbox) ─ */

const EX_COUNTER = `# counter.pyxl

# Count lives in Python. The @action
# mutates it on the server (sandboxed here).
count = 0

@server
async def load(request):
    return {"count": count}

@action
async def increment(request):
    global count
    count += 1
    return {"count": count}


import React, { useState } from 'react';
import { useAction } from 'pyxle/client';

export default function Counter({ data }) {
    const [count, setCount] = useState(data.count);
    const increment = useAction('increment');

    async function bump() {
        const res = await increment();
        if (res.ok) setCount(res.count);
    }

    return (
        <div className="card">
            <span className="tag">state lives in Python</span>
            <h1>{count}</h1>
            <p>Each click runs the @action — real Python.</p>
            <button onClick={bump} disabled={increment.pending}>
                {increment.pending ? 'Running…' : 'Increment +'}
            </button>
        </div>
    );
}`;

const EX_LOADER = `# greeting.pyxl

# @server runs on the server and returns a dict —
# it becomes your React props. No fetch, no API route.
@server
async def load(request):
    stack = ["Python", "React", "Starlette", "Vite"]
    return {
        "title": "Loaded by @server",
        "stack": stack,
        "count": len(stack),
    }


import React from 'react';

export default function Page({ data }) {
    return (
        <div className="card">
            <span className="tag">{data.count} items · from @server</span>
            <h1>{data.title}</h1>
            <ul>
                {data.stack.map((item, i) => (
                    <li key={i}>{item}</li>
                ))}
            </ul>
        </div>
    );
}`;

const EX_TODO = `# todo.pyxl

# The list lives in Python. Each @action mutates it
# on the server and returns the new state.
todos = [
    {"id": 1, "text": "Try the playground", "done": True},
    {"id": 2, "text": "Build a real feature", "done": False},
]
_next_id = 3

@server
async def load(request):
    return {"todos": todos}

@action
async def toggle(request):
    body = await request.json()
    for t in todos:
        if t["id"] == body["id"]:
            t["done"] = not t["done"]
    return {"todos": todos}

@action
async def add(request):
    global _next_id
    body = await request.json()
    todos.append({"id": _next_id, "text": body["text"], "done": False})
    _next_id += 1
    return {"todos": todos}


import React, { useState } from 'react';
import { useAction } from 'pyxle/client';

export default function Todo({ data }) {
    const [todos, setTodos] = useState(data.todos);
    const [text, setText] = useState('');
    const toggle = useAction('toggle');
    const add = useAction('add');

    async function onToggle(id) {
        const r = await toggle({ id });
        if (r.ok) setTodos(r.todos);
    }
    async function onAdd() {
        if (!text.trim()) return;
        const r = await add({ text });
        if (r.ok) { setTodos(r.todos); setText(''); }
    }

    return (
        <div className="card">
            <span className="tag">state on the server</span>
            <h1>Todos</h1>
            <ul>
                {todos.map((t) => (
                    <li key={t.id} onClick={() => onToggle(t.id)} style={{ cursor: 'pointer' }}>
                        {t.done ? '✓ ' : '○ '}{t.text}
                    </li>
                ))}
            </ul>
            <input value={text} onChange={(e) => setText(e.target.value)} placeholder="New todo…" />
            <button onClick={onAdd}>Add todo</button>
        </div>
    );
}`;

const EX_FORM = `# signup.pyxl

# @action validates on the server and raises
# ActionError — useAction surfaces it on the client.
from pyxle.runtime import ActionError

@server
async def load(request):
    return {}

@action
async def signup(request):
    body = await request.json()
    email = (body.get("email") or "").strip()
    if "@" not in email:
        raise ActionError("Please enter a valid email.")
    return {"message": f"Welcome aboard, {email}!"}


import React, { useState } from 'react';
import { useAction } from 'pyxle/client';

export default function Signup({ data }) {
    const [email, setEmail] = useState('');
    const [msg, setMsg] = useState(null);
    const signup = useAction('signup');

    async function onSubmit() {
        const r = await signup({ email });
        setMsg({ ok: r.ok, text: r.ok ? r.message : r.error });
    }

    return (
        <div className="card">
            <span className="tag">validated on the server</span>
            <h1>Join the list</h1>
            <input value={email} onChange={(e) => setEmail(e.target.value)} placeholder="you@example.com" />
            <button onClick={onSubmit} disabled={signup.pending}>
                {signup.pending ? 'Submitting…' : 'Sign up'}
            </button>
            {msg && <p style={{ color: msg.ok ? '#059669' : '#dc2626' }}>{msg.text}</p>}
        </div>
    );
}`;

