            {/* The editor */}
            <div className="reveal relative mx-auto mt-6 max-w-5xl" style={{ animationDelay: '240ms' }}>
                <div aria-hidden="true" className="pointer-events-none absolute -inset-x-8 -top-10 bottom-0 -z-10 opacity-70 blur-2xl"
                    style={{ background: 'radial-gradient(60% 50% at 50% 0%, rgba(16,185,129,0.24), rgba(59,130,246,0.13) 55%, transparent 78%)' }} />
                <div className="gradient-edge rounded-2xl p-px shadow-2xl shadow-emerald-500/10 dark:shadow-black/50">
                    <div className="overflow-hidden rounded-2xl bg-[#0b0b0d] dark:bg-[#0c0c0e]">
                        <LivePlayground initialSource={ex.source} fileLabel={ex.file} paneHeight="h-[440px] sm:h-[520px]" />
