                <div className="absolute inset-0 grid-bg opacity-50" />
                <div className="aurora aurora-anim parallax-slow absolute -inset-x-10 -top-48 h-[720px] origin-top" />
                <div className="absolute inset-x-0 bottom-0 h-40 bg-gradient-to-b from-transparent to-white dark:to-[#0a0a0b]" />
            </div>

            <div className="relative mx-auto max-w-3xl text-center">
                <span className="reveal inline-flex items-center gap-2 rounded-full border px-3 py-1 text-xs font-medium border-zinc-200 bg-white/60 text-zinc-700 dark:border-white/10 dark:bg-white/5 dark:text-zinc-300 backdrop-blur">
                    <span className="relative flex h-1.5 w-1.5">
                        <span className="absolute inline-flex h-full w-full animate-ping rounded-full bg-emerald-400 opacity-70" />
                        <span className="relative inline-flex h-1.5 w-1.5 rounded-full bg-emerald-500" />
                    </span>
                    Live · zero install
                </span>
                <h1 className="reveal mt-6 text-balance text-4xl font-semibold leading-[1.0] tracking-[-0.03em] sm:text-6xl" style={{ animationDelay: '60ms' }}>
                    Pyxle, live. <span className="gradient-text">No install.</span>
                </h1>
                <p className="reveal mx-auto mt-6 max-w-xl text-pretty text-base sm:text-lg text-zinc-600 dark:text-zinc-400" style={{ animationDelay: '120ms' }}>
                    Write a real <code className="rounded px-1.5 py-0.5 text-[0.85em] text-emerald-700 dark:text-emerald-400 bg-emerald-500/10">.pyxl</code> and run it instantly — the actual Pyxle parser plus your <code className="rounded px-1.5 py-0.5 text-[0.85em] text-emerald-700 dark:text-emerald-400 bg-emerald-500/10">@server</code> and <code className="rounded px-1.5 py-0.5 text-[0.85em] text-emerald-700 dark:text-emerald-400 bg-emerald-500/10">@action</code> code, in an isolated sandbox. Zero install, nothing leaves your machine. In a real app this Python runs server-side on Starlette — the playground just simulates that here.
                </p>
            </div>

            {/* Example switcher */}
            <div className="reveal relative mx-auto mt-10 flex max-w-5xl flex-wrap items-center justify-center gap-2" style={{ animationDelay: '180ms' }} role="tablist" aria-label="Examples">
                {EXAMPLES.map((e, idx) => (
                    <button
                        key={e.id}
                        type="button"
                        role="tab"
                        aria-selected={idx === i}
                        onClick={() => setI(idx)}
                        className={`focus-ring inline-flex items-center gap-2 rounded-full border px-3.5 py-1.5 text-sm transition-colors ${
                            idx === i
                                ? 'border-emerald-500/30 bg-emerald-500/10 text-emerald-700 dark:text-emerald-300'
                                : 'border-zinc-200 bg-white text-zinc-600 hover:bg-zinc-50 dark:border-white/10 dark:bg-white/5 dark:text-zinc-400 dark:hover:bg-white/10'
                        }`}
                    >
                        <span className="font-medium">{e.label}</span>
                        <span className="hidden font-mono text-[10px] opacity-60 sm:inline">{e.blurb}</span>
                    </button>
