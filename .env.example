# pyxle.dev environment — copy to `.env` and fill in real values.
#
# `.env` is gitignored; THIS file (.env.example) is committed as a template, so
# it must stay placeholders-only — never put a real secret here.
# With none of these set, the site still runs: the admin panel is disabled and
# mail is logged to the console (nothing is sent).

# ── Admin panel — GET /api/subscribers (HTTP Basic Auth) ──────────────
PYXLE_ADMIN_USERNAME=admin
# [required to enable the admin panel] the endpoint returns 401 while unset.
PYXLE_ADMIN_PASSWORD=change-me

# ── App secret — signs unsubscribe links and CSRF tokens ──────────────
# [REQUIRED IN PRODUCTION] If unset, unsubscribe links fall back to a public
# dev key and become forgeable. Generate a strong value with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
PYXLE_SECRET_KEY=change-me-to-a-strong-random-value

# ── Mail (pyxle-mail plugin) ──────────────────────────────────────────
# Provider: console (logs, sends nothing — the default) | smtp | resend
PYXLE_MAIL_PROVIDER=console
# [required for smtp/resend] default sender; must be a verified address/domain.
PYXLE_MAIL_FROM=hello@mail.pyxle.dev
PYXLE_MAIL_FROM_NAME=Shivam from Pyxle
# Replies go here (the welcome email invites a reply); keep it on the apex.
PYXLE_MAIL_REPLY_TO=shivam@pyxle.dev

# Resend transactional API (set PYXLE_MAIL_PROVIDER=resend)
# PYXLE_MAIL_RESEND_API_KEY=re_your_api_key_here

# SMTP (set PYXLE_MAIL_PROVIDER=smtp) — local dev example targets Mailpit
# PYXLE_MAIL_SMTP_HOST=127.0.0.1
# PYXLE_MAIL_SMTP_PORT=1025
# PYXLE_MAIL_SMTP_TLS=false
# PYXLE_MAIL_SMTP_USERNAME=
# PYXLE_MAIL_SMTP_PASSWORD=
# PYXLE_MAIL_SMTP_SSL=false

# ── Resend webhook — POST /api/resend-webhook (Svix-signed) ───────────
# [required if you configure the Resend webhook] the endpoint's signing secret.
# PYXLE_RESEND_WEBHOOK_SECRET=whsec_your_signing_secret

# ── Bot protection — Cloudflare Turnstile on the subscribe form ───────
# Both keys come from Cloudflare → Turnstile.
#  • SITE key is public → uses the PYXLE_PUBLIC_ prefix so it reaches the client
#    (read as import.meta.env.PYXLE_PUBLIC_TURNSTILE_SITE_KEY). It's injected
#    when `pyxle dev`/`pyxle build` runs, so set it in the BUILD env.
#  • SECRET is server-side, read at request time.
# If both are unset, the form skips the bot check (fine for local dev).
# Cloudflare always-pass TEST keys:
#   site 1x00000000000000000000AA  /  secret 1x0000000000000000000000000000000AA
# PYXLE_PUBLIC_TURNSTILE_SITE_KEY=
# PYXLE_TURNSTILE_SECRET=
